---
interface Props {
  chart: string;
  title?: string;
}

const { chart, title } = Astro.props;
---

<div class="mermaid-wrapper my-8">
  {title && <h4 class="text-lg font-semibold text-gray-800 mb-3">{title}</h4>}
  <div class="mermaid bg-white rounded-xl border border-gray-200 p-6 overflow-x-auto">
    {chart}
  </div>
</div>
