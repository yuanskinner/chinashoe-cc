---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQItem[];
  title?: string;
}

const { faqs, title = 'Frequently Asked Questions' } = Astro.props;
---

<section class="mt-12 mb-8" aria-labelledby="faq-heading">
  <h2 id="faq-heading" class="text-2xl font-bold text-neutral-900 mb-6">{title}</h2>
  <div class="space-y-4">
    {faqs.map((faq, index) => (
      <details class="group bg-white border border-neutral-200 rounded-lg overflow-hidden" open={index === 0}>
        <summary class="flex items-center justify-between cursor-pointer px-6 py-4 text-left font-medium text-neutral-900 hover:bg-neutral-50 transition-colors">
          <span class="pr-4">{faq.question}</span>
          <svg class="w-5 h-5 text-neutral-500 flex-shrink-0 transform group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="px-6 py-4 text-neutral-600 border-t border-neutral-100 bg-neutral-50">
          <p>{faq.answer}</p>
        </div>
      </details>
    ))}
  </div>
</section>
