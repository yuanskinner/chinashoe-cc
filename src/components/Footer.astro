---
import { footerNavItems } from '@utils/seo';

const currentYear = new Date().getFullYear();
---

<footer class="bg-neutral-900 text-white">
  <!-- Newsletter Section -->
  <div class="border-b border-neutral-800">
    <div class="container-custom py-12">
      <div class="max-w-2xl mx-auto text-center">
        <h3 class="text-2xl font-bold mb-3">Stay Updated with Industry Insights</h3>
        <p class="text-neutral-400 mb-6">Get the latest footwear trends, supplier updates, and market analysis delivered to your inbox.</p>
        <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" onsubmit="event.preventDefault(); alert('Newsletter subscription feature is coming soon!');">
          <input
            type="email"
            placeholder="Enter your email"
            class="flex-1 px-4 py-3 rounded-lg bg-neutral-800 border border-neutral-700 text-white placeholder-neutral-500 focus:ring-2 focus:ring-primary-500 focus:border-transparent"
            required
          />
          <button type="submit" class="btn-primary whitespace-nowrap">
            Subscribe
          </button>
        </form>
        <p class="text-xs text-neutral-500 mt-3">No spam. Unsubscribe anytime.</p>
      </div>
    </div>
  </div>

  <!-- Main Footer -->
  <div class="container-custom py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-8 lg:gap-12">
      <!-- Brand Column -->
      <div class="col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <img src="/favicon.svg" alt="ChinaShoe.cc" class="w-10 h-10" />
          <div>
            <span class="text-xl font-bold text-white">ChinaShoe</span>
            <span class="text-xl font-bold text-primary-400">.cc</span>
          </div>
        </a>
        <p class="text-neutral-400 text-sm leading-relaxed mb-4">
          Your trusted B2B footwear knowledge hub. Connecting global shoe buyers with Chinese manufacturers and industry insights.
        </p>
        <div class="flex gap-4 items-center">
          <!-- WhatsApp -->
          <a href="https://wa.me/8615986707004" target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-green-400 transition-colors" aria-label="WhatsApp">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
          <!-- Email -->
          <a href="mailto:Nicole99124@gmail.com" class="text-neutral-400 hover:text-white transition-colors" aria-label="Email">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </a>
          <!-- LinkedIn -->
          <a href="https://www.linkedin.cn/incareer/in/chunzhang2025" target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-blue-400 transition-colors" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <!-- Instagram -->
          <a href="https://www.instagram.com/women_shoes9012" target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-pink-400 transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <!-- Facebook -->
          <a href="https://www.facebook.com/p/Lady-shoes-factory-in-china-100065057501406" target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-blue-500 transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="font-semibold text-white mb-4">Resources</h4>
        <ul class="space-y-2">
          {footerNavItems.resources.map(item => (
            <li>
              <a href={item.href} class="text-neutral-400 hover:text-white transition-colors text-sm">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Categories -->
      <div>
        <h4 class="font-semibold text-white mb-4">Categories</h4>
        <ul class="space-y-2">
          {footerNavItems.categories.map(item => (
            <li>
              <a href={item.href} class="text-neutral-400 hover:text-white transition-colors text-sm">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="font-semibold text-white mb-4">Company</h4>
        <ul class="space-y-2">
          {footerNavItems.company.map(item => (
            <li>
              <a href={item.href} class="text-neutral-400 hover:text-white transition-colors text-sm">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-semibold text-white mb-4">Contact</h4>
        <ul class="space-y-3 text-sm text-neutral-400">
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:Nicole99124@gmail.com" class="hover:text-white transition-colors">
              Nicole99124@gmail.com
            </a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Guangzhou, China</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-neutral-800">
    <div class="container-custom py-6">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-neutral-500">
        <p>&copy; {currentYear} ChinaShoe.cc. All rights reserved.</p>
        <div class="flex items-center gap-6">
          <a href="/privacy/" class="hover:text-white transition-colors">Privacy Policy</a>
          <a href="/terms/" class="hover:text-white transition-colors">Terms of Service</a>
          <a href="/sitemap-index.xml" class="hover:text-white transition-colors">Sitemap</a>
        </div>
      </div>
    </div>
  </div>
</footer>
