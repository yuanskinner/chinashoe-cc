---
import PageLayout from '@layouts/PageLayout.astro';
---

<PageLayout
  title="Contact Us"
  description="Get in touch with ChinaShoe.cc. Contact our team for inquiries about suppliers, partnerships, or general questions."
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Contact', url: '/contact/' },
  ]}
>
  <div class="mb-8">
    <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
      Contact Us
    </h1>
    <p class="text-lg text-neutral-600">
      We'd love to hear from you. Reach out for inquiries, partnerships, or any questions about our platform.
    </p>
  </div>

  <div class="grid lg:grid-cols-3 gap-8">
    <!-- Contact Form -->
    <div class="lg:col-span-2">
      <div class="card">
        <h2 class="text-xl font-bold text-neutral-900 mb-6">Send us a message</h2>
        <form class="space-y-6">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium text-neutral-700 mb-2">
                Full Name *
              </label>
              <input
                type="text"
                id="name"
                name="name"
                class="input"
                placeholder="John Smith"
                required
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-neutral-700 mb-2">
                Email Address *
              </label>
              <input
                type="email"
                id="email"
                name="email"
                class="input"
                placeholder="john@company.com"
                required
              />
            </div>
          </div>
          
          <div>
            <label for="company" class="block text-sm font-medium text-neutral-700 mb-2">
              Company Name
            </label>
            <input
              type="text"
              id="company"
              name="company"
              class="input"
              placeholder="Your Company Ltd."
            />
          </div>

          <div>
            <label for="inquiry" class="block text-sm font-medium text-neutral-700 mb-2">
              Inquiry Type *
            </label>
            <select id="inquiry" name="inquiry" class="input" required>
              <option value="">Select an option</option>
              <option value="supplier">Supplier Request</option>
              <option value="partnership">Business Partnership</option>
              <option value="content">Content Collaboration</option>
              <option value="technical">Technical Support</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-neutral-700 mb-2">
              Message *
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              class="input"
              placeholder="How can we help you?"
              required
            ></textarea>
          </div>

          <button type="submit" class="btn-primary w-full md:w-auto">
            Send Message
          </button>
        </form>
      </div>
    </div>

    <!-- Contact Info -->
    <div class="space-y-6">
      <div class="card">
        <h3 class="font-semibold text-neutral-900 mb-4">Contact Information</h3>
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <div>
              <div class="font-medium text-neutral-900">Email</div>
              <a href="mailto:contact@chinashoe.cc" class="text-primary-600 hover:text-primary-700">
                contact@chinashoe.cc
              </a>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <div>
              <div class="font-medium text-neutral-900">Office</div>
              <div class="text-neutral-600">Guangzhou, Guangdong<br />China</div>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
              <div class="font-medium text-neutral-900">Business Hours</div>
              <div class="text-neutral-600">Mon - Fri: 9:00 AM - 6:00 PM CST</div>
            </div>
          </div>
        </div>
      </div>

      <div class="card">
        <h3 class="font-semibold text-neutral-900 mb-4">Follow Us</h3>
        <div class="flex gap-4">
          <a href="https://linkedin.com/company/chinashoe" class="w-10 h-10 rounded-lg bg-neutral-100 flex items-center justify-center text-neutral-600 hover:bg-primary-100 hover:text-primary-600 transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="https://twitter.com/chinashoecc" class="w-10 h-10 rounded-lg bg-neutral-100 flex items-center justify-center text-neutral-600 hover:bg-primary-100 hover:text-primary-600 transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</PageLayout>
