---
import BaseLayout from '@layouts/BaseLayout.astro';

const categories = [
  {
    name: 'Running Shoes',
    description: 'Road, trail, and racing footwear',
    href: '/encyclopedia/running-shoes/',
    icon: '🏃',
    count: '156 articles',
  },
  {
    name: 'Leather Shoes',
    description: 'Formal and dress footwear',
    href: '/encyclopedia/leather-shoes/',
    icon: '👞',
    count: '124 articles',
  },
  {
    name: 'Sneakers',
    description: 'Casual and lifestyle footwear',
    href: '/encyclopedia/sneakers/',
    icon: '👟',
    count: '98 articles',
  },
  {
    name: 'Safety Shoes',
    description: 'Industrial and protective footwear',
    href: '/encyclopedia/safety-shoes/',
    icon: '🥾',
    count: '67 articles',
  },
  {
    name: "Children's Shoes",
    description: 'Kids footwear from infant to youth',
    href: '/encyclopedia/children-shoes/',
    icon: '🧸',
    count: '45 articles',
  },
  {
    name: 'Sandals & Slippers',
    description: 'Open-toe and casual footwear',
    href: '/encyclopedia/sandals/',
    icon: '🩴',
    count: '52 articles',
  },
];

const latestNews = [
  {
    title: 'Vietnam Emerges as Key Alternative for Chinese Shoe Manufacturing',
    excerpt: 'As labor costs rise in China, Vietnamese factories are attracting more B2B orders from European retailers.',
    date: '2024-12-15',
    category: 'Industry News',
    href: '/news/vietnam-shoe-manufacturing-2024/',
  },
  {
    title: 'Sustainable Materials Gain Traction in Athletic Footwear',
    excerpt: 'Major brands are committing to recycled and bio-based materials in their 2025 product lines.',
    date: '2024-12-12',
    category: 'Trends',
    href: '/news/sustainable-footwear-materials-2025/',
  },
  {
    title: 'Dongguan Shoe Fair 2025: Key Dates and Registration',
    excerpt: 'China\'s premier footwear trade show announces dates for spring exhibition.',
    date: '2024-12-10',
    category: 'Events',
    href: '/news/dongguan-shoe-fair-2025/',
  },
];

const featuredSuppliers = [
  {
    name: 'BALAA Shoe',
    location: 'Chengdu, Sichuan',
    specialization: "Women's Fashion Shoes, High Heels, Sandals, Boots",
    certifications: ['Gold Supplier 2yrs', '100% Response Rate', '≤2h Response'],
    image: '/images/suppliers/balaa-shoe.jpg',
    href: '/suppliers/balaa-shoe/',
  },
  {
    name: 'BRARA Shoes',
    location: 'Chengdu, Sichuan',
    specialization: "Women's Fashion Shoes, Casual Shoes, Customized Boots",
    certifications: ['Gold Supplier 8yrs', '1,000+ Transactions', '95.65% Response'],
    image: '/images/suppliers/brara-shoe.jpg',
    href: '/suppliers/brara-shoe/',
  },
  {
    name: 'Guangdong Perfect Footwear',
    location: 'Dongguan, Guangdong',
    specialization: 'Running Shoes, Basketball Shoes, Sports Sneakers',
    certifications: ['BSCI', 'ISO 9001', 'Verified'],
    image: '/images/suppliers/guangdong-perfect.jpg',
    href: '/suppliers/guangdong-perfect-footwear/',
  },
  {
    name: 'Fujian Yili Shoes',
    location: 'Quanzhou, Fujian',
    specialization: 'Sports Shoes, Hiking Shoes, Outdoor Footwear',
    certifications: ['BSCI', 'SEDEX', 'Verified'],
    image: '/images/suppliers/fujian-yili.jpg',
    href: '/suppliers/fujian-yili-shoes/',
  },
  {
    name: 'Wenzhou Huachen Leather Goods',
    location: 'Wenzhou, Zhejiang',
    specialization: 'Oxford Shoes, Derby Shoes, Loafers',
    certifications: ['BSCI', 'Sedex', 'Verified'],
    image: '/images/suppliers/wenzhou-huachen.jpg',
    href: '/suppliers/wenzhou-huachen/',
  },
  {
    name: 'Qingdao Safety First',
    location: 'Qingdao, Shandong',
    specialization: 'Safety Shoes, Work Boots, Steel Toe Cap Shoes',
    certifications: ['EN ISO 20345', 'ASTM F2413', 'Verified'],
    image: '/images/suppliers/qingdao-safety.jpg',
    href: '/suppliers/qingdao-safety-first/',
  },
];

const stats = [
  { value: '5,000+', label: 'Verified Suppliers' },
  { value: '600+', label: 'Industry Articles' },
  { value: '50+', label: 'Countries Covered' },
  { value: '10K+', label: 'Monthly Visitors' },
];
---

<BaseLayout
  title="ChinaShoe.cc - B2B Footwear Knowledge Hub"
  description="Your trusted B2B footwear knowledge hub. Connect with verified Chinese manufacturers, explore comprehensive shoe guides, and stay updated with industry trends."
  type="website"
>
  <!-- Hero Section -->
  <section class="relative text-white overflow-hidden bg-gradient-to-br from-neutral-900 via-neutral-900 to-primary-900">
    <!-- Decorative Elements -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-20 left-10 w-72 h-72 bg-primary-500 rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-20 w-96 h-96 bg-primary-600 rounded-full blur-3xl"></div>
    </div>
    
    <div class="container-custom relative z-10">
      <div class="py-20 md:py-28 lg:py-36 flex flex-col items-center text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary-500/20 border border-primary-500/30 text-primary-300 text-sm font-medium mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          Your trusted B2B footwear knowledge hub
        </div>
        
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight text-white">
          Connect with <span class="text-primary-400">Chinese Footwear</span> Manufacturers
        </h1>
        
        <p class="text-lg md:text-xl text-neutral-200 mb-8 max-w-2xl">
          From design inspiration to supplier verification, we provide comprehensive resources for footwear designers, wholesalers, and retailers worldwide.
        </p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
          <a href="/suppliers/" class="btn-primary text-lg px-8 py-3">
            Find Suppliers
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/encyclopedia/" class="inline-flex items-center gap-2 border-2 border-white/40 text-white hover:bg-white/10 text-lg px-8 py-3 rounded-lg font-semibold transition-colors">
            Explore Encyclopedia
          </a>
        </div>
        
        <!-- Pagefind Search Bar -->
        <div class="w-full max-w-xl" id="search-container">
          <div class="bg-white/95 backdrop-blur-sm rounded-xl p-2 flex items-center gap-2 shadow-2xl">
            <svg class="w-5 h-5 text-neutral-400 ml-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              id="hero-search"
              type="search"
              placeholder="Search shoes, suppliers, materials..."
              class="flex-1 px-4 py-3 text-neutral-900 bg-transparent border-0 focus:ring-0 focus:outline-none"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-12 bg-white border-b border-neutral-200">
    <div class="container-custom">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map(stat => (
          <div class="text-center">
            <div class="text-3xl md:text-4xl font-bold text-primary-600 mb-1">
              {stat.value}
            </div>
            <div class="text-neutral-600 text-sm">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Categories Section -->
  <section class="section bg-neutral-50">
    <div class="container-custom">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
          Explore Footwear Categories
        </h2>
        <p class="text-neutral-600 max-w-2xl mx-auto">
          Browse our comprehensive encyclopedia covering all major footwear types, from athletic to formal wear.
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {categories.map(category => (
          <a
            href={category.href}
            class="card group hover:border-primary-300 border border-transparent"
          >
            <div class="flex items-start gap-4">
              <span class="text-4xl">{category.icon}</span>
              <div class="flex-1">
                <h3 class="font-semibold text-lg text-neutral-900 group-hover:text-primary-600 transition-colors mb-1">
                  {category.name}
                </h3>
                <p class="text-neutral-600 text-sm mb-2">
                  {category.description}
                </p>
                <span class="text-xs text-primary-600 font-medium">
                  {category.count}
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
      
      <div class="text-center mt-10">
        <a href="/encyclopedia/" class="link-arrow">
          View All Categories
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Suppliers Section -->
  <section class="section bg-white">
    <div class="container-custom">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
            Featured Suppliers
          </h2>
          <p class="text-neutral-600 max-w-2xl">
            Verified manufacturers from China's premier footwear production regions.
          </p>
        </div>
        <a href="/suppliers/" class="link-arrow">
          View All Suppliers
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
      
      <div class="grid md:grid-cols-3 gap-6">
        {featuredSuppliers.map(supplier => (
          <a href={supplier.href} class="card group p-0 overflow-hidden">
            <div class="h-40 overflow-hidden">
              <img
                src={supplier.image}
                alt={supplier.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
            <div class="p-4">
              <div class="flex items-center justify-between mb-2">
                <h3 class="font-semibold text-lg text-neutral-900 group-hover:text-primary-600 transition-colors">
                  {supplier.name}
                </h3>
                <span class="badge-success">Verified</span>
              </div>
              
              <div class="flex items-center gap-2 text-sm text-neutral-500 mb-3">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                {supplier.location}
              </div>
              
              <p class="text-sm text-neutral-600 mb-3">
                {supplier.specialization}
              </p>
              
              <div class="flex flex-wrap gap-2">
                {supplier.certifications.map(cert => (
                  <span class="text-xs px-2 py-1 bg-neutral-100 text-neutral-600 rounded">
                    {cert}
                  </span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest News Section -->
  <section class="section bg-neutral-50">
    <div class="container-custom">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
            Industry News & Trends
          </h2>
          <p class="text-neutral-600 max-w-2xl">
            Stay updated with the latest developments in global footwear manufacturing and trade.
          </p>
        </div>
        <a href="/news/" class="link-arrow">
          View All News
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
      
      <div class="grid md:grid-cols-3 gap-6">
        {latestNews.map(article => (
          <a href={article.href} class="card group">
            <div class="flex items-center gap-3 mb-3">
              <span class="badge-primary">{article.category}</span>
              <span class="text-sm text-neutral-500">{article.date}</span>
            </div>
            
            <h3 class="font-semibold text-lg text-neutral-900 group-hover:text-primary-600 transition-colors mb-2 line-clamp-2">
              {article.title}
            </h3>
            
            <p class="text-neutral-600 text-sm line-clamp-2">
              {article.excerpt}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-r from-primary-600 to-primary-700 text-white">
    <div class="container-custom text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Ready to Source Your Next Footwear Line?
      </h2>
      <p class="text-primary-100 max-w-2xl mx-auto mb-8">
        Access our comprehensive supplier database, detailed manufacturing guides, and expert consultation services.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/sourcing/" class="bg-white text-primary-700 px-8 py-3 rounded-lg font-semibold hover:bg-primary-50 transition-colors">
          Start Sourcing Guide
        </a>
        <a href="/contact/" class="border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white/10 transition-colors">
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
