---
import BaseLayout from '@layouts/BaseLayout.astro';

const categories = [
  {
    name: 'Running Shoes',
    description: 'Road, trail, and racing footwear',
    href: '/encyclopedia/running-shoes/',
    icon: '🏃',
    count: '156 articles',
  },
  {
    name: 'Leather Shoes',
    description: 'Formal and dress footwear',
    href: '/encyclopedia/leather-shoes/',
    icon: '👞',
    count: '124 articles',
  },
  {
    name: 'Sneakers',
    description: 'Casual and lifestyle footwear',
    href: '/encyclopedia/sneakers/',
    icon: '👟',
    count: '98 articles',
  },
  {
    name: 'Safety Shoes',
    description: 'Industrial and protective footwear',
    href: '/encyclopedia/safety-shoes/',
    icon: '🥾',
    count: '67 articles',
  },
  {
    name: "Children's Shoes",
    description: 'Kids footwear from infant to youth',
    href: '/encyclopedia/children-shoes/',
    icon: '🧸',
    count: '45 articles',
  },
  {
    name: 'Sandals & Slippers',
    description: 'Open-toe and casual footwear',
    href: '/encyclopedia/sandals/',
    icon: '🩴',
    count: '52 articles',
  },
];

const latestNews = [
  {
    title: 'Vietnam Emerges as Key Alternative for Chinese Shoe Manufacturing',
    excerpt: 'As labor costs rise in China, Vietnamese factories are attracting more B2B orders from European retailers.',
    date: '2024-12-15',
    category: 'Industry News',
    href: '/news/vietnam-shoe-manufacturing/',
  },
  {
    title: 'Sustainable Materials Gain Traction in Athletic Footwear',
    excerpt: 'Major brands are committing to recycled and bio-based materials in their 2025 product lines.',
    date: '2024-12-12',
    category: 'Trends',
    href: '/news/sustainable-footwear-materials/',
  },
  {
    title: 'Dongguan Shoe Fair 2025: Key Dates and Registration',
    excerpt: 'China\'s premier footwear trade show announces dates for spring exhibition.',
    date: '2024-12-10',
    category: 'Events',
    href: '/news/dongguan-shoe-fair/',
  },
];

const featuredSuppliers = [
  {
    name: 'BALAA Shoe',
    location: 'Chengdu, Sichuan',
    specialization: "Women's Fashion Shoes, High Heels, Sandals, Boots",
    certifications: ['Gold Supplier 2yrs', '100% Response Rate', '≤2h Response'],
    href: '/suppliers/balaa-shoe/',
  },
  {
    name: 'BRARA Shoes',
    location: 'Chengdu, Sichuan',
    specialization: "Women's Fashion Shoes, Casual Shoes, Customized Boots",
    certifications: ['Gold Supplier 8yrs', '1,000+ Transactions', '95.65% Response'],
    href: '/suppliers/brara-shoe/',
  },
  {
    name: 'Wenzhou Huachen Leather Goods',
    location: 'Wenzhou, Zhejiang',
    specialization: 'Leather Shoes, Dress Shoes',
    certifications: ['BSCI', 'Sedex'],
    href: '/suppliers/wenzhou-huachen/',
  },
];

const stats = [
  { value: '5,000+', label: 'Verified Suppliers' },
  { value: '600+', label: 'Industry Articles' },
  { value: '50+', label: 'Countries Covered' },
  { value: '10K+', label: 'Monthly Visitors' },
];
---

<BaseLayout
  title="ChinaShoe.cc - B2B Footwear Knowledge Hub"
  description="Your trusted B2B footwear knowledge hub. Connect with verified Chinese manufacturers, explore comprehensive shoe guides, and stay updated with industry trends."
  type="website"
>
  <!-- Hero Section -->
  <section class="relative text-white overflow-hidden min-h-[600px]">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <img src="/images/hero-craftsman.jpg" alt="Master craftsman handcrafting red leather high heel shoes" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-neutral-900/95 via-neutral-900/80 to-neutral-900/60"></div>
    </div>
    <!-- Subtle Pattern Overlay -->
    <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
    
    <div class="relative container-custom py-20 lg:py-28">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary-500/20 border border-primary-500/30 text-primary-300 text-sm font-medium mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          Your trusted B2B footwear knowledge hub
        </div>
        
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight text-white">
          Connect with <span class="text-primary-400">Chinese Footwear</span> Manufacturers
        </h1>
        
        <p class="text-lg md:text-xl text-neutral-300 mb-8 max-w-2xl mx-auto">
          From design inspiration to supplier verification, we provide comprehensive resources for footwear designers, wholesalers, and retailers worldwide.
        </p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
          <a href="/suppliers/" class="btn-primary text-lg px-8 py-3">
            Find Suppliers
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/encyclopedia/" class="btn-outline border-white text-white hover:bg-white/10 text-lg px-8 py-3">
            Explore Encyclopedia
          </a>
        </div>
        
        <!-- Search Bar -->
        <div class="max-w-2xl mx-auto">
          <div class="bg-white rounded-xl p-2 flex items-center gap-2 shadow-2xl">
            <svg class="w-5 h-5 text-neutral-400 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              type="search"
              placeholder="Search shoes, suppliers, materials, processes..."
              class="flex-1 px-4 py-3 text-neutral-900 border-0 focus:ring-0"
              onkeydown="if(event.key==='Enter') { event.preventDefault(); alert('Search feature is coming soon! Stay tuned.'); }"
            />
            <button type="button" class="btn-primary px-6 py-3" onclick="alert('Search feature is coming soon! Stay tuned.');">
              Search
            </button>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Wave Decoration -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 50L60 45C120 40 240 30 360 35C480 40 600 60 720 65C840 70 960 60 1080 50C1200 40 1320 30 1380 25L1440 20V100H1380C1320 100 1200 100 1080 100C960 100 840 100 720 100C600 100 480 100 360 100C240 100 120 100 60 100H0V50Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-12 bg-white border-b border-neutral-200">
    <div class="container-custom">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map(stat => (
          <div class="text-center">
            <div class="text-3xl md:text-4xl font-bold text-primary-600 mb-1">
              {stat.value}
            </div>
            <div class="text-neutral-600 text-sm">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Categories Section -->
  <section class="section bg-neutral-50">
    <div class="container-custom">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
          Explore Footwear Categories
        </h2>
        <p class="text-neutral-600 max-w-2xl mx-auto">
          Browse our comprehensive encyclopedia covering all major footwear types, from athletic to formal wear.
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {categories.map(category => (
          <a
            href={category.href}
            class="card group hover:border-primary-300 border border-transparent"
          >
            <div class="flex items-start gap-4">
              <span class="text-4xl">{category.icon}</span>
              <div class="flex-1">
                <h3 class="font-semibold text-lg text-neutral-900 group-hover:text-primary-600 transition-colors mb-1">
                  {category.name}
                </h3>
                <p class="text-neutral-600 text-sm mb-2">
                  {category.description}
                </p>
                <span class="text-xs text-primary-600 font-medium">
                  {category.count}
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
      
      <div class="text-center mt-10">
        <a href="/encyclopedia/" class="link-arrow">
          View All Categories
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Suppliers Section -->
  <section class="section bg-white">
    <div class="container-custom">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
            Featured Suppliers
          </h2>
          <p class="text-neutral-600 max-w-2xl">
            Verified manufacturers from China's premier footwear production regions.
          </p>
        </div>
        <a href="/suppliers/" class="link-arrow">
          View All Suppliers
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
      
      <div class="grid md:grid-cols-3 gap-6">
        {featuredSuppliers.map(supplier => (
          <a href={supplier.href} class="card group">
            <div class="flex items-center justify-between mb-4">
              <div class="w-12 h-12 rounded-lg bg-primary-100 flex items-center justify-center">
                <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
              </div>
              <span class="badge-success">Verified</span>
            </div>
            
            <h3 class="font-semibold text-lg text-neutral-900 group-hover:text-primary-600 transition-colors mb-2">
              {supplier.name}
            </h3>
            
            <div class="flex items-center gap-2 text-sm text-neutral-500 mb-3">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              {supplier.location}
            </div>
            
            <p class="text-sm text-neutral-600 mb-4">
              Specialization: {supplier.specialization}
            </p>
            
            <div class="flex flex-wrap gap-2">
              {supplier.certifications.map(cert => (
                <span class="text-xs px-2 py-1 bg-neutral-100 text-neutral-600 rounded">
                  {cert}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest News Section -->
  <section class="section bg-neutral-50">
    <div class="container-custom">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
            Industry News & Trends
          </h2>
          <p class="text-neutral-600 max-w-2xl">
            Stay updated with the latest developments in global footwear manufacturing and trade.
          </p>
        </div>
        <a href="/news/" class="link-arrow">
          View All News
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
      
      <div class="grid md:grid-cols-3 gap-6">
        {latestNews.map(article => (
          <a href={article.href} class="card group">
            <div class="flex items-center gap-3 mb-3">
              <span class="badge-primary">{article.category}</span>
              <span class="text-sm text-neutral-500">{article.date}</span>
            </div>
            
            <h3 class="font-semibold text-lg text-neutral-900 group-hover:text-primary-600 transition-colors mb-2 line-clamp-2">
              {article.title}
            </h3>
            
            <p class="text-neutral-600 text-sm line-clamp-2">
              {article.excerpt}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-r from-primary-600 to-primary-700 text-white">
    <div class="container-custom text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Ready to Source Your Next Footwear Line?
      </h2>
      <p class="text-primary-100 max-w-2xl mx-auto mb-8">
        Access our comprehensive supplier database, detailed manufacturing guides, and expert consultation services.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/sourcing/" class="bg-white text-primary-700 px-8 py-3 rounded-lg font-semibold hover:bg-primary-50 transition-colors">
          Start Sourcing Guide
        </a>
        <a href="/contact/" class="border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white/10 transition-colors">
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
