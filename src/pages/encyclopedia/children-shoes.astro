---

<PageLayout
  title="Children's Shoes Encyclopedia - ChinaShoe.cc"
  description="Complete guide to children's shoes: safety standards, sizing, materials, and sourcing from Chinese manufacturers."
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Encyclopedia', url: '/encyclopedia/' },
    { name: "Children's Shoes", url: '/encyclopedia/children-shoes/' },
  ]}
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-pink-600 via-purple-600 to-indigo-700 text-white py-16">
    <div class="container-custom">
      <div class="flex items-center gap-2 text-sm text-white/80 mb-4">
        <a href="/encyclopedia/" class="hover:text-white transition-colors">Encyclopedia</a>
