      <p class="text-base text-gray-500">Of footwear upper materials</p>
    </div>
    <div class="card p-6">
      <p class="text-lg text-green-700 font-medium mb-2">Innovation Rate</p>
      <p class="text-4xl font-bold text-green-900 mb-2">High</p>
