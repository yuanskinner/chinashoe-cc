        { label: 'Overview', href: '/encyclopedia/materials/synthetic/', active: true },
        { label: 'PU Leather', href: '/encyclopedia/materials/pu-leather/' },
        { label: 'Microfiber', href: '/encyclopedia/materials/microfiber/' },
        { label: 'Mesh & Knit', href: '/encyclopedia/materials/mesh-fabric/' },
        { label: 'TPU Materials', href: '/encyclopedia/materials/tpu/' },
      ],
    },
    {
      title: 'Related Materials',
      links: [
        { label: 'Leather', href: '/encyclopedia/materials/leather/' },
        { label: 'Rubber Soles', href: '/encyclopedia/materials/rubber-soles/' },
