        DIN abrasion below 30 mm³.
      </p>
    </div>
    <div class="card text-center">
      <div class="text-4xl mb-4">♻️</div>
      <h3 class="font-semibold text-lg mb-2">Recyclable</h3>
      <p class="text-neutral-600 text-sm">
        100% thermoplastic - fully recyclable.
      </p>
    </div>
    <div class="card text-center">
      <div class="text-4xl mb-4">🎨</div>
      <h3 class="font-semibold text-lg mb-2">Color Stable</h3>
      <p class="text-neutral-600 text-sm">
        Excellent colorability and retention.
      </p>
    </div>
  </div>

  <!-- Article Grid -->
  <h2 class="text-2xl font-bold text-neutral-900 mb-6">Explore Topics</h2>
  <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
    {features.map(article => (
      <a href={article.href} class="card group overflow-hidden p-0">
        <div class="aspect-video overflow-hidden">
          <img
            src={article.image}
            alt={article.title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          />
        </div>
        <div class="p-4">
          <h3 class="font-semibold text-lg mb-2 group-hover:text-blue-600 transition-colors">
            {article.title}
          </h3>
          <p class="text-neutral-600 text-sm">
            {article.description}
          </p>
