    description: 'The complete sole elevation: from espadrilles to modern designs.',
    image: 'https://images.unsplash.com/photo-1560769629-975ec94e6a86?w=400&h=300&fit=crop',
    href: '/encyclopedia/high-heels/wedge/',
  },
  {
    title: 'Kitten Heels',
    description: 'The elegant low heel: from Audrey Hepburn to modern fashion.',
    image: 'https://images.unsplash.com/photo-1596703263926-eb0762ee17e4?w=400&h=300&fit=crop',
    href: '/encyclopedia/high-heels/kitten-heel/',
  },
];

const relatedCategories = [
  { name: 'Sandals', href: '/encyclopedia/sandals/', count: 52 },
  { name: 'Pumps', href: '/encyclopedia/pumps/', count: 38 },
  { name: 'Boots', href: '/encyclopedia/boots/', count: 95 },
];
---

<PageLayout
  title="High Heels Guide"
  description="Complete guide to high heels: stiletto, block heel, wedge, and kitten heel styles. Learn about heel types, comfort considerations, and how to choose the right heel height."
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Encyclopedia', url: '/encyclopedia/' },
    { name: 'High Heels', url: '/encyclopedia/high-heels/' },
  ]}
  sidebarItems={[
    {
      title: 'High Heels',
      links: [
        { label: 'Overview', href: '/encyclopedia/high-heels/', active: true },
        { label: 'Stiletto Heels', href: '/encyclopedia/high-heels/stiletto/' },
        { label: 'Block Heels', href: '/encyclopedia/high-heels/block-heel/' },
        { label: 'Wedge Heels', href: '/encyclopedia/high-heels/wedge/' },
        { label: 'Kitten Heels', href: '/encyclopedia/high-heels/kitten-heel/' },
      ],
    },
    {
      title: 'Related Categories',
      links: [
        { label: 'Sandals', href: '/encyclopedia/sandals/' },
        { label: 'Pumps', href: '/encyclopedia/pumps/' },
        { label: 'Boots', href: '/encyclopedia/boots/' },
      ],
    },
  ]}
>
  <div class="mb-8">
    <span class="badge-primary mb-2">Women's Footwear</span>
    <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
      High Heels Guide
    </h1>
    <p class="text-lg text-neutral-600">
      Everything you need to know about high heels: from classic stilettos to practical block heels. Explore heel types, comfort considerations, and styling guidelines.
    </p>
  </div>

  <!-- Featured Image -->
  <div class="rounded-xl overflow-hidden mb-8">
    <img
      src="https://images.unsplash.com/photo-1543163521-1bf539c55dd2?w=1200&h=400&fit=crop"
      alt="Elegant High Heels"
      class="w-full h-64 md:h-80 object-cover"
    />
  </div>

  <!-- Introduction Content -->
  <div class="prose prose-lg max-w-none mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Understanding High Heels</h2>
    
    <p class="text-neutral-600 mb-4">
      High heels are shoes where the heel, compared with the toe, is significantly elevated. Beyond their practical function of adding height, high heels have become powerful fashion statements that can transform an outfit and boost confidence. From the boardroom to special occasions, high heels remain an essential element of women's footwear wardrobes worldwide.
    </p>
    
    <p class="text-neutral-600 mb-4">
      The history of high heels spans centuries and cultures, from Egyptian butchers' platform shoes (for practical reasons) to Renaissance European nobility (for status). The modern high heel as we know it emerged in the 1950s with Christian Dior's introduction of the stiletto, which became an instant icon of feminine elegance.
    </p>
    
    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Types of High Heels</h3>
    
    <p class="text-neutral-600 mb-4">
      <strong>Stiletto Heels:</strong> Characterized by their thin, tapering heel, stilettos are the most iconic and feminine high heel style. They elongate the leg and create a dramatic silhouette but require practice and may cause discomfort during extended wear. Heel heights typically range from 3 to 6 inches (7.5 to 15 cm).
    </p>
    
    <p class="text-neutral-600 mb-4">
      <strong>Block Heels:</strong> Also known as chunky heels, these feature a thick, sturdy heel that provides excellent stability and support. Block heels offer a more practical option for all-day wear while still adding height and visual impact. They're versatile enough for professional settings and casual occasions.
    </p>
    
    <p class="text-neutral-600 mb-4">
      <strong>Wedge Heels:</strong> Unlike traditional heels that elevate only the back of the shoe, wedges feature a solid sole that elevates the entire foot from heel to toe. This design distributes weight more evenly and provides excellent stability, making wedges a comfortable choice for extended wear.
    </p>
    
    <p class="text-neutral-600 mb-4">
      <strong>Kitten Heels:</strong> These low heels, typically 1.5 to 2 inches (4-5 cm) tall, offer a sophisticated alternative to higher heels. Named for their subtle, demure appearance, kitten heels have experienced various revivals in fashion history, from Audrey Hepburn's iconic looks to modern minimalist fashion.
    </p>
    
    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Materials and Construction</h3>
    
    <p class="text-neutral-600 mb-4">
      High heels are constructed from various materials that affect both aesthetics and durability. Leather and suede uppers offer premium quality and comfort, conforming to the foot over time. Synthetic materials provide more affordable options with consistent quality and easier maintenance.
    </p>
    
    <p class="text-neutral-600 mb-4">
      The heel itself may be constructed from various materials including wood (for traditional block heels), metal (for stilettos), resin, or injected plastic. The quality of heel construction directly impacts durability and safety, making it an important consideration when sourcing high heels.
    </p>
    
    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Comfort Considerations</h3>
    
    <p class="text-neutral-600 mb-4">
      Heel height is measured from the bottom of the heel to where it meets the sole at the toe. Moderate heels (2-3 inches) generally offer the best balance of style and comfort for most occasions. Higher heels shift body weight forward, increasing pressure on the ball of the foot and may affect posture and gait.
    </p>
    
    <p class="text-neutral-600 mb-4">
      Features that improve heel comfort include cushioned insoles, arch support, padding around the ankle collar, and stable heel bases. Some high heels incorporate advanced cushioning technologies borrowed from athletic footwear, including gel inserts and memory foam padding.
    </p>
    
    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Sourcing Considerations for B2B Buyers</h3>
    
    <p class="text-neutral-600 mb-4">
      China is a major producer of women's high heels, with major manufacturing hubs including Chengdu (Sichuan) for fashion footwear and Guangdong province for various women's shoe categories. When sourcing high heels from China, key considerations include heel stability testing, material quality, and finishing standards.
    </p>
    
    <p class="text-neutral-600 mb-4">
      Quality high heels require precise construction to ensure proper weight distribution and heel attachment. Request samples to evaluate heel stability, stitching quality, and material consistency. Pay particular attention to the attachment method between the upper and heel, as this is a common point of failure in lower-quality shoes.
    </p>
  </div>

  <!-- Key Sections -->
  <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
    <div class="card text-center">
      <div class="text-4xl mb-4">📍</div>
      <h3 class="font-semibold text-lg mb-2">Stiletto</h3>
      <p class="text-neutral-600 text-sm">
        The iconic thin heel for maximum elegance and dramatic height.
      </p>
    </div>
    <div class="card text-center">
      <div class="text-4xl mb-4">🧱</div>
      <h3 class="font-semibold text-lg mb-2">Block Heel</h3>
      <p class="text-neutral-600 text-sm">
        Sturdy and stable for all-day comfort without sacrificing style.
      </p>
    </div>
    <div class="card text-center">
      <div class="text-4xl mb-4">📐</div>
      <h3 class="font-semibold text-lg mb-2">Wedge</h3>
      <p class="text-neutral-600 text-sm">
        Complete sole elevation for maximum stability and comfort.
      </p>
    </div>
    <div class="card text-center">
      <div class="text-4xl mb-4">🌸</div>
      <h3 class="font-semibold text-lg mb-2">Kitten Heel</h3>
      <p class="text-neutral-600 text-sm">
        Subtle elegance with a low, sophisticated profile.
      </p>
    </div>
  </div>

  <!-- Article Grid -->
  <h2 class="text-2xl font-bold text-neutral-900 mb-6">Explore Topics</h2>
  <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
    {features.map(article => (
      <a href={article.href} class="card group overflow-hidden p-0">
        <div class="aspect-video overflow-hidden">
          <img
            src={article.image}
            alt={article.title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          />
        </div>
        <div class="p-4">
          <h3 class="font-semibold text-neutral-900 group-hover:text-primary-600 transition-colors mb-2">
            {article.title}
          </h3>
          <p class="text-sm text-neutral-600">
            {article.description}
          </p>
        </div>
      </a>
    ))}
  </div>

  <!-- Related Categories -->
  <div class="border-t border-neutral-200 pt-8">
    <h3 class="text-lg font-semibold text-neutral-900 mb-4">Related Categories</h3>
    <div class="flex flex-wrap gap-3">
      {relatedCategories.map(cat => (
        <a href={cat.href} class="inline-flex items-center justify-between gap-2 px-4 py-2 bg-neutral-100 rounded-lg hover:bg-neutral-200 transition-colors">
          <span class="font-medium text-neutral-700">{cat.name}</span>
          <span class="text-sm text-neutral-500">({cat.count})</span>
        </a>
      ))}
    </div>
  </div>
</PageLayout>
