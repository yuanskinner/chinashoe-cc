---
import PageLayout from '../../layouts/PageLayout.astro';


const categories = [
  { name: 'Stiletto Heels', url: '/encyclopedia/high-heels/stiletto/', description: 'Thin high heels', count: 24 },
  { name: 'Block Heels', url: '/encyclopedia/high-heels/block/', description: 'Stable chunky heels', count: 28 },
  { name: 'Wedge Heels', url: '/encyclopedia/high-heels/wedge/', description: 'Wedge sole shoes', count: 18 },
  { name: 'Kitten Heels', url: '/encyclopedia/high-heels/kitten/', description: 'Low modest heels', count: 20 },
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "High Heels Manufacturing Encyclopedia - ChinaShoe.cc",
  "description": "Complete guide to high heel engineering: heel types, construction methods, foot health, and sourcing from Chinese manufacturers.",
};
---

<PageLayout
  title="High Heels Manufacturing Guide - ChinaShoe.cc"
  type="article"
  description="Deep dive into high heel engineering: stiletto vs block heels, steel shank construction, lasting techniques, and sourcing from Chinese factories."
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Encyclopedia', url: '/encyclopedia/' },
    { name: "Women's Footwear", url: '/encyclopedia/womens-shoes/' },
    { name: 'High Heels', url: '/encyclopedia/high-heels/' },
  ]}
  structuredData={structuredData}
>
  <section class="py-12 bg-gradient-to-b from-primary-50 to-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary-100 rounded-full text-primary-700 text-sm font-medium mb-6">
          <span>Professional Guide</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          High Heels Manufacturing <span class="text-primary-600">Encyclopedia</span>
        </h1>
        <p class="text-xl text-gray-600 leading-relaxed">
          High heels have evolved from Renaissance platforms to the sleek stiletto. 
          Behind every elegant heel lies sophisticated engineering: steel shanks, 
          balanced weight distribution, and precise lasting techniques.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        
        {/* Heel Types */}
        <div class="mb-16">
          <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
            <span class="w-8 h-8 bg-primary-100 rounded-lg flex items-center justify-center text-primary-600">1</span>
            Heel Types & Specifications
          </h2>
          
          <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="bg-white rounded-2xl shadow-lg p-6 border border-gray-100">
              <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center text-2xl mb-4">📍</div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2">Stiletto</h3>
              <p class="text-gray-600 text-sm mb-4">
                Thin steel-reinforced heel. 
                3-10cm height. Maximum height. 
                Most challenging to walk in.
              </p>
              <ul class="text-xs text-gray-500 space-y-1">
                <li>• Steel rod core</li>
                <li>• Laminated wood top</li>
                <li>• Leather or rubber tip</li>
              </ul>
            </div>
            
            <div class="bg-white rounded-2xl shadow-lg p-6 border border-gray-100">
              <div class="w-12 h-12 bg-secondary-100 rounded-xl flex items-center justify-center text-2xl mb-4">🧱</div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2">Block Heel</h3>
              <p class="text-gray-600 text-sm mb-4">
                Wide, sturdy heel. 
                3-8cm height. More stable. 
                Better for all-day wear.
              </p>
              <ul class="text-xs text-gray-500 space-y-1">
                <li>• Solid construction</li>
                <li>• Wood or molded stack</li>
                <li>• Maximum stability</li>
              </ul>
            </div>
            
            <div class="bg-white rounded-2xl shadow-lg p-6 border border-gray-100">
              <div class="w-12 h-12 bg-accent-100 rounded-xl flex items-center justify-center text-2xl mb-4">📐</div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2">Wedge Heel</h3>
              <p class="text-gray-600 text-sm mb-4">
                Solid sole-to-ground wedge. 
                Even weight distribution. 
                Platform front optional.
              </p>
              <ul class="text-xs text-gray-500 space-y-1">
                <li>• Cork or EVA core</li>
                <li>• Full sole coverage</li>
                <li>• Summer styles popular</li>
              </ul>
            </div>
            
            <div class="bg-white rounded-2xl shadow-lg p-6 border border-gray-100">
              <div class="w-12 h-12 bg-gray-200 rounded-xl flex items-center justify-center text-2xl mb-4">🌱</div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2">Kitten Heel</h3>
              <p class="text-gray-600 text-sm mb-4">
                Low, slender heel. 
                3-5cm height. Elegant comfort. 
                Office appropriate.
              </p>
              <ul class="text-xs text-gray-500 space-y-1">
                <li>• Subtle lift</li>
                <li>• Easy walking</li>
                <li>• Professional style</li>
              </ul>
            </div>
          </div>
        </div>

        {/* Construction */}
        <div class="mb-16">
          <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
            <span class="w-8 h-8 bg-secondary-100 rounded-lg flex items-center justify-center text-secondary-600">2</span>
            Heel Construction Engineering
          </h2>
          
          <div class="bg-white rounded-2xl shadow-lg p-8 border border-gray-100">
            <div class="grid md:grid-cols-2 gap-8 mb-8">
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Stiletto Construction</h3>
                <p class="text-gray-600 mb-4">
                  The stiletto's elegance comes from sophisticated internal engineering. 
                  A steel rod provides strength while minimizing bulk.
                </p>
                <div class="space-y-4">
                  <div class="p-4 bg-gray-50 rounded-xl">
                    <h4 class="font-semibold text-gray-800 mb-2">Steel Shank System</h4>
                    <p class="text-gray-600 text-sm">
                      Full-length steel rod from heel to ball. 
                      Typically 6-8mm width. Provides rigidity. 
                      Should flex at toe, not at arch.
                    </p>
                  </div>
                  <div class="p-4 bg-gray-50 rounded-xl">
                    <h4 class="font-semibold text-gray-800 mb-2">Heel Pin Construction</h4>
                    <p class="text-gray-600 text-sm">
                      Multiple pins secure heel to upper. 
                      Side pins for lateral stability. 
                      Counter pins prevent rotation.
                    </p>
                  </div>
                </div>
              </div>
              
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Heel Height vs Balance</h3>
                <p class="text-gray-600 mb-4">
                  Higher heels shift weight forward, increasing pressure on the ball 
                  of the foot. Proper design redistributes load.
                </p>
                <div class="space-y-4">
                  <div class="border-l-4 border-primary-500 pl-4">
                    <h4 class="font-semibold text-gray-800">5cm Heel</h4>
                    <p class="text-gray-600 text-sm">
                      25% increased forefoot pressure. 
                      Generally comfortable for all-day. 
                      Sweet spot for dress heels.
                    </p>
                  </div>
                  <div class="border-l-4 border-accent-500 pl-4">
                    <h4 class="font-semibold text-gray-800">8-10cm Heel</h4>
                    <p class="text-gray-600 text-sm">
                      75% increased forefoot pressure. 
                      Limit to 3-4 hours. 
                      Requires practice to walk.
                    </p>
                  </div>
                  <div class="border-l-4 border-secondary-500 pl-4">
                    <h4 class="font-semibold text-gray-800">Platform Compensation</h4>
                    <p class="text-gray-600 text-sm">
                      3cm platform reduces effective height by 3cm. 
                      Reduces foot angle. 
                      More comfortable at same height.
                    </p>
                  </div>
                </div>
              </div>
            </div>
            
            <div class="p-6 bg-red-50 rounded-xl">
              <h3 class="text-lg font-semibold text-red-800 mb-3">Heel Attachment Methods</h3>
              <div class="grid md:grid-cols-3 gap-4 text-sm text-red-700">
                <div>
                  <h4 class="font-medium mb-1">Nailed Construction</h4>
                  <p class="text-xs">Finishing nails into wood heel. Standard method.</p>
                </div>
                <div>
                  <h4 class="font-medium mb-1">Screwed</h4>
                  <p class="text-xs">Machine screws. More secure for heavy heels.</p>
                </div>
                <div>
                  <h4 class="font-medium mb-1">Welded</h4>
                  <p class="text-xs">Plastic components fused. Molded heels.</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* Last Design */}
        <div class="mb-16">
          <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
            <span class="w-8 h-8 bg-accent-100 rounded-lg flex items-center justify-center text-accent-600">3</span>
            High Heel Last Design
          </h2>
          
          <div class="bg-white rounded-2xl shadow-lg p-8 border border-gray-100">
            <p class="text-gray-600 mb-8">
              The last determines the shoe's shape, fit, and walking mechanics. 
              High heel lasts require specialized modifications from standard patterns.
            </p>
            
            <div class="grid md:grid-cols-2 gap-8">
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Key Modifications</h3>
                <div class="space-y-4">
                  <div class="p-4 bg-gray-50 rounded-xl">
                    <h4 class="font-semibold text-gray-800">Pitch Angle</h4>
                    <p class="text-gray-600 text-sm">
                      Angle from heel seat to toe. 
                      Standard: 15-20°. 
                      High fashion: 25-35°.
                    </p>
                  </div>
                  <div class="p-4 bg-gray-50 rounded-xl">
                    <h4 class="font-semibold text-gray-800">Heel Seat Position</h4>
                    <p class="text-gray-600 text-sm">
                      Heel center under the calcaneus. 
                      Too far back: instability. 
                      Too far forward: toe pressure.
                    </p>
                  </div>
                  <div class="p-4 bg-gray-50 rounded-xl">
                    <h4 class="font-semibold text-gray-800">Toe Box Volume</h4>
                    <p class="text-gray-600 text-sm">
                      Reduced volume in pointed styles. 
                      Must accommodate natural toe spread. 
                      Critical for comfort.
                    </p>
                  </div>
                </div>
              </div>
              
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Insole & Arch Support</h3>
                <div class="space-y-4">
                  <div class="border-l-4 border-primary-500 pl-4">
                    <h4 class="font-semibold text-gray-800">Steel Shank</h4>
                    <p class="text-gray-600 text-sm">
                      Extends from heel to ball. 
                      Prevents sole flexing. 
                      Supports arch.
                    </p>
                  </div>
                  <div class="border-l-4 border-secondary-500 pl-4">
                    <h4 class="font-semibold text-gray-800">Metatarsal Pad</h4>
                    <p class="text-gray-600 text-sm">
                      Optional pad behind ball. 
                      Redistributes pressure. 
                      Added comfort feature.
                    </p>
                  </div>
                  <div class="border-l-4 border-accent-500 pl-4">
                    <h4 class="font-semibold text-gray-800">Contoured Insole</h4>
                    <p class="text-gray-600 text-sm">
                      Molded arch shape. 
                      Maintains shape over time. 
                      Premium feature.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* Sourcing */}
        <div class="mb-16">
          <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
            <span class="w-8 h-8 bg-primary-100 rounded-lg flex items-center justify-center text-primary-600">4</span>
            Manufacturing & Sourcing
          </h2>
          
          <div class="bg-white rounded-2xl shadow-lg p-8 border border-gray-100">
            <div class="grid md:grid-cols-2 gap-8">
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-4">China Production Regions</h3>
                <div class="space-y-4">
                  <div class="p-4 bg-gray-50 rounded-xl">
                    <h4 class="font-semibold text-gray-900 text-sm">Wenzhou, Zhejiang</h4>
                    <p class="text-gray-600 text-xs mt-1">
                      Largest women's heel production. 
                      All price points. 
                      Standard and fashion quality.
                    </p>
                    <p class="text-primary-600 text-xs font-medium mt-2">MOQ: 300 pairs | Lead: 30-45 days</p>
                  </div>
                  <div class="p-4 bg-gray-50 rounded-xl">
                    <h4 class="font-semibold text-gray-900 text-sm">Chengdu, Sichuan</h4>
                    <p class="text-gray-600 text-xs mt-1">
                      Quality leather heels. 
                      Italian-style last development. 
                      Better finishing standards.
                    </p>
                    <p class="text-primary-600 text-xs font-medium mt-2">MOQ: 200 pairs | Lead: 40-55 days</p>
                  </div>
                </div>
              </div>
              
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Cost Breakdown (Per Pair)</h3>
                <div class="space-y-3">
                  <div class="flex justify-between items-center py-2 border-b border-gray-100">
                    <span class="text-gray-600 text-sm">Upper Leather/Satin</span>
                    <span class="font-semibold text-gray-900">$6.00-18.00</span>
                  </div>
                  <div class="flex justify-between items-center py-2 border-b border-gray-100">
                    <span class="text-gray-600 text-sm">Steel Shank</span>
                    <span class="font-semibold text-gray-900">$1.00-2.50</span>
                  </div>
                  <div class="flex justify-between items-center py-2 border-b border-gray-100">
                    <span class="text-gray-600 text-sm">Heel (Wood/Steel)</span>
                    <span class="font-semibold text-gray-900">$2.00-8.00</span>
                  </div>
                  <div class="flex justify-between items-center py-2 border-b border-gray-100">
                    <span class="text-gray-600 text-sm">Insole + Lining</span>
                    <span class="font-semibold text-gray-900">$2.00-5.00</span>
                  </div>
                  <div class="flex justify-between items-center py-2 border-b border-gray-100">
                    <span class="text-gray-600 text-sm">Outsole</span>
                    <span class="font-semibold text-gray-900">$1.50-4.00</span>
                  </div>
                  <div class="flex justify-between items-center py-2 border-b border-gray-100">
                    <span class="text-gray-600 text-sm">Assembly Labor</span>
                    <span class="font-semibold text-gray-900">$4.00-12.00</span>
                  </div>
                  <div class="flex justify-between items-center py-3 bg-primary-50 px-4 rounded-lg">
                    <span class="font-semibold text-gray-900">Total FOB (Fashion)</span>
                    <span class="font-bold text-primary-600">$20.00-52.00</span>
                  </div>
                  <div class="flex justify-between items-center py-3 bg-secondary-50 px-4 rounded-lg">
                    <span class="font-semibold text-gray-900">Total FOB (Premium)</span>
                    <span class="font-bold text-secondary-600">$35.00-85.00</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* Related */}
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Related Categories</h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
    {categories.map(cat => (
      <a href={cat.url} class="bg-white rounded-xl shadow-md p-6 border border-gray-100 hover:shadow-lg hover:border-primary-200 transition-all group">
        <h3 class="font-semibold text-gray-900 group-hover:text-primary-600 transition-colors mb-2">
          {cat.name}
        </h3>
        <p class="text-gray-600 text-sm mb-3">{cat.description}</p>
        <span class="text-primary-600 text-sm font-medium">{cat.count} articles</span>
      </a>
    ))}
  </div>
        </div>

      </div>
    </div>
  </section>
</PageLayout>
