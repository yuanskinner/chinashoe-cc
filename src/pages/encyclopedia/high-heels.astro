    description: 'Stability and style: the practical choice for all-day comfort.',
    image: 'https://images.unsplash.com/photo-1515347619252-60a4bf4fff4f?w=400&h=300&fit=crop',
    href: '/encyclopedia/high-heels/block-heel/',
  },
  {
