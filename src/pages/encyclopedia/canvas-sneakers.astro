      <p class="text-neutral-600 text-sm">
        Affordable pricing.
      </p>
    </div>
  </div>

  <!-- Article Grid -->
  <h2 class="text-2xl font-bold text-neutral-900 mb-6">Explore Topics</h2>
  <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
    {features.map(article => (
      <a href={article.href} class="card group overflow-hidden p-0">
        <div class="aspect-video overflow-hidden">
          <img
            src={article.image}
            alt={article.title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          />
        </div>
        <div class="p-4">
          <h3 class="font-semibold text-lg mb-2 group-hover:text-blue-600 transition-colors">
            {article.title}
          </h3>
          <p class="text-neutral-600 text-sm">
            {article.description}
          </p>
        </div>
      </a>
    ))}
  </div>

  <!-- Related Categories -->
  <h2 class="text-2xl font-bold text-neutral-900 mb-6">Related Content</h2>
  <div class="flex flex-wrap gap-3">
    {relatedCategories.map(cat => (
      <a href={cat.href} class="badge badge-outline">
        {cat.name} ({cat.count})
      </a>
    ))}
  </div>
</PageLayout>
