---
import PageLayout from '../../layouts/PageLayout.astro';


const categories = [
  { name: 'Penny Loafers', url: '/encyclopedia/loafers/', description: 'Classic saddle strap design', count: 22 },
  { name: 'Tassel Loafers', url: '/encyclopedia/loafers/', description: 'Italian-inspired decoration', count: 18 },
  { name: 'Horsebit Loafers', url: '/encyclopedia/loafers/', description: 'Gucci signature style', count: 15 },
  { name: 'Slipper-style Loafers', url: '/encyclopedia/slippers/', description: 'Velvet and formal versions', count: 12 },
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Loafers Encyclopedia - ChinaShoe.cc",
  "description": "Complete guide to loafers: penny, tassel, horsebit styles, construction techniques, and sourcing from Chinese manufacturers.",
};
---

<PageLayout
  title="Loafers Manufacturing Guide - ChinaShoe.cc"
  type="article"
  description="Deep dive into loafer engineering: penny, tassel, and horsebit styles, moccasin construction, leather vs suede variations, and sourcing from Chinese factories."
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Encyclopedia', url: '/encyclopedia/' },
    { name: 'Formal & Dress', url: '/encyclopedia/leather-shoes/' },
    { name: 'Loafers', url: '/encyclopedia/loafers/' },
  ]}
  structuredData={structuredData}
>
  <section class="py-12 bg-gradient-to-b from-primary-50 to-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary-100 rounded-full text-primary-700 text-sm font-medium mb-6">
          <span>Professional Guide</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          Loafers Manufacturing <span class="text-primary-600">Encyclopedia</span>
        </h1>
        <p class="text-xl text-gray-600 leading-relaxed">
          The loafer represents effortless elegance—a shoe you simply slip into. 
          Born from Norwegian farmers and perfected by Italian cordwainers, 
          loafers have evolved into essential wardrobe staples. Explore the 
          craftsmanship behind each style variation.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        
        {/* Style Variations */}
        <div class="mb-16">
          <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
            <span class="w-8 h-8 bg-primary-100 rounded-lg flex items-center justify-center text-primary-600">1</span>
            Classic Loafer Styles
          </h2>
          
          <div class="bg-white rounded-2xl shadow-lg p-8 border border-gray-100">
            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
              <div class="bg-gradient-to-b from-amber-50 to-white rounded-xl p-6 border border-amber-200">
                <div class="text-4xl mb-4">💰</div>
                <h3 class="font-semibold text-gray-900 mb-2">Penny Loafer</h3>
                <p class="text-gray-600 text-sm mb-3">
                  American classic. Leather strap with diamond-shaped opening 
                  originally held a penny (or car key). Timeless simplicity.
                </p>
                <ul class="text-xs text-gray-500 space-y-1">
                  <li>• 1930s Bass Weejun origin</li>
                  <li>• Narrow or wide strap</li>
                  <li>• Business casual staple</li>
                </ul>
              </div>
              
              <div class="bg-gradient-to-b from-orange-50 to-white rounded-xl p-6 border border-orange-200">
                <div class="text-4xl mb-4">🎗️</div>
                <h3 class="font-semibold text-gray-900 mb-2">Tassel Loafer</h3>
                <p class="text-gray-600 text-sm mb-3">
                  Italian elegance with decorative tassels at tongue. 
                  Brook's Brothers popularized in America. 
                  Semi-formal to formal occasions.
                </p>
                <ul class="text-xs text-gray-500 space-y-1">
                  <li>• Alden tassel as icon</li>
                  <li>• Tassels: leather or silk</li>
                  <li>• Bold or subtle colors</li>
                </ul>
              </div>
              
              <div class="bg-gradient-to-b from-gray-100 to-white rounded-xl p-6 border border-gray-300">
                <div class="text-4xl mb-4">🐴</div>
                <h3 class="font-semibold text-gray-900 mb-2">Horsebit Loafer</h3>
                <p class="text-gray-600 text-sm mb-3">
                  Gucci signature. Double strap with metal bit. 
                  Italian luxury icon since 1953. 
                  Highest formality among loafers.
                </p>
                <ul class="text-xs text-gray-500 space-y-1">
                  <li>• Requires metal hardware</li>
                  <li>• Pronged or looped bit</li>
                  <li>• Can be worn with suits</li>
                </ul>
              </div>
              
              <div class="bg-gradient-to-b from-purple-50 to-white rounded-xl p-6 border border-purple-200">
                <div class="text-4xl mb-4">👑</div>
                <h3 class="font-semibold text-gray-900 mb-2">Slipper Loafer</h3>
                <p class="text-gray-600 text-sm mb-3">
                  Velvet or brocade uppers. Evening wear essential. 
                  Traditional black or midnight blue. 
                  Worn with tuxedo or formal suits.
                </p>
                <ul class="text-xs text-gray-500 space-y-1">
                  <li>• Prince Albert shape</li>
                  <li>• Silk or velvet upper</li>
                  <li>• Gold or silver bit optional</li>
                </ul>
              </div>
            </div>
            
            <div class="p-6 bg-gray-50 rounded-xl">
              <h3 class="text-lg font-semibold text-gray-900 mb-4">Formality Hierarchy</h3>
              <div class="flex items-center justify-between text-sm">
                <div class="text-center px-4">
                  <div class="w-16 h-16 bg-gray-200 rounded-full mx-auto mb-2 flex items-center justify-center">👔</div>
                  <p class="font-medium">Suit</p>
                  <p class="text-gray-500 text-xs">Horsebit, Slipper</p>
                </div>
                <div class="text-center px-4">
                  <div class="w-16 h-16 bg-gray-200 rounded-full mx-auto mb-2 flex items-center justify-center">👨‍💼</div>
                  <p class="font-medium">Business</p>
                  <p class="text-gray-500 text-xs">Tassel, Penny</p>
                </div>
                <div class="text-center px-4">
                  <div class="w-16 h-16 bg-gray-200 rounded-full mx-auto mb-2 flex items-center justify-center">👨‍🎓</div>
                  <p class="font-medium">Business Casual</p>
                  <p class="text-gray-500 text-xs">Penny, Suede</p>
                </div>
                <div class="text-center px-4">
                  <div class="w-16 h-16 bg-gray-200 rounded-full mx-auto mb-2 flex items-center justify-center">🎓</div>
                  <p class="font-medium">Smart Casual</p>
                  <p class="text-gray-500 text-xs">Suede Loafers</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* Construction */}
        <div class="mb-16">
          <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
            <span class="w-8 h-8 bg-secondary-100 rounded-lg flex items-center justify-center text-secondary-600">2</span>
            Loafer Construction Techniques
          </h2>
          
          <div class="bg-white rounded-2xl shadow-lg p-8 border border-gray-100">
            <p class="text-gray-600 mb-8">
              Loafers require specialized construction techniques distinct from lace-ups. 
              The seamless "moccasin" construction is central to their character.
            </p>
            
            <div class="grid md:grid-cols-2 gap-8 mb-8">
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Moccasin Construction</h3>
                <div class="space-y-4">
                  <div class="p-4 bg-gray-50 rounded-xl">
                    <h4 class="font-semibold text-gray-800 mb-2">True Moccasin Upper</h4>
                    <p class="text-gray-600 text-sm">
                      Single piece of leather wraps around foot. 
                      Penny strap sewn on top. Hand-stitched seam at toe.
                    </p>
                  </div>
                  <div class="p-4 bg-gray-50 rounded-xl">
                    <h4 class="font-semibold text-gray-800 mb-2">Gum Side</h4>
                    <p class="text-gray-600 text-sm">
                      Visible stitching where upper meets sole. 
                      "Hand-stitched" appearance even if machine-made.
                    </p>
                  </div>
                  <div class="p-4 bg-gray-50 rounded-xl">
                    <h4 class="font-semibold text-gray-800 mb-2">Vamp Thickness</h4>
                    <p class="text-gray-600 text-sm">
                      Usually 1.0-1.4mm for flexibility. 
                      Thicker vamp adds structure.
                    </p>
                  </div>
                </div>
              </div>
              
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Sole Assembly</h3>
                <div class="space-y-4">
                  <div class="border-l-4 border-primary-500 pl-4">
                    <h4 class="font-semibold text-gray-800">Norwegian Sole</h4>
                    <p class="text-gray-600 text-sm">
                      Visible "stitching" channel around perimeter. 
                      Adds thickness and durability. Classic look.
                    </p>
                  </div>
                  <div class="border-l-4 border-secondary-500 pl-4">
                    <h4 class="font-semibold text-gray-800">Fiddle Back</h4>
                    <p class="text-gray-600 text-sm">
                      Curved waist indentation. Italian styling. 
                      Reduces visual bulk at arch.
                    </p>
                  </div>
                  <div class="border-l-4 border-accent-500 pl-4">
                    <h4 class="font-semibold text-gray-800">Rubber Sole Option</h4>
                    <p class="text-gray-600 text-sm">
                      Leather top with rubber bottom. 
                      Tod's Gommino style. Casual comfort.
                    </p>
                  </div>
                </div>
              </div>
            </div>
            
            <div class="p-6 bg-amber-50 rounded-xl">
              <h3 class="text-lg font-semibold text-amber-800 mb-3">Chinese Loafer Manufacturing Expertise</h3>
              <div class="grid md:grid-cols-3 gap-4 text-sm text-amber-700">
                <div>
                  <h4 class="font-medium mb-2">Strengths</h4>
                  <ul class="space-y-1 text-xs">
                    <li>• Leather moccasin lasting</li>
                    <li>• Consistent strap placement</li>
                    <li>• Quality hardware sourcing</li>
                    <li>• Competitive pricing</li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-medium mb-2">Challenges</h4>
                  <ul class="space-y-1 text-xs">
                    <li>• True hand-stitching rare</li>
                    <li>• "Fish mouth" seam quality</li>
                    <li>• Hardware (bits) plating</li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-medium mb-2">Quality Tips</h4>
                  <ul class="space-y-1 text-xs">
                    <li>• Request "piping" edge detail</li>
                    <li>• Check strap stitching density</li>
                    <li>• Verify hardware attachment</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* Material Selection */}
        <div class="mb-16">
          <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
            <span class="w-8 h-8 bg-accent-100 rounded-lg flex items-center justify-center text-accent-600">3</span>
            Loafer Material Selection
          </h2>
          
          <div class="bg-white rounded-2xl shadow-lg p-8 border border-gray-100">
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-gray-200 bg-gray-50">
                    <th class="text-left py-3 px-4 font-semibold text-gray-700">Material</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-700">Best For</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-700">Formality</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-700">Durability</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-700">Care</th>
                  </tr>
                </thead>
                <tbody class="text-gray-600">
                  <tr class="border-b border-gray-100">
                    <td class="py-3 px-4 font-medium">Calf Leather</td>
                    <td class="py-3 px-4">Year-round dress</td>
                    <td class="py-3 px-4">High</td>
                    <td class="py-3 px-4">Very Good</td>
                    <td class="py-3 px-4">Polish regularly</td>
                  </tr>
                  <tr class="border-b border-gray-100">
                    <td class="py-3 px-4 font-medium">Pebbled Leather</td>
                    <td class="py-3 px-4">Casual wear</td>
                    <td class="py-3 px-4">Medium</td>
                    <td class="py-3 px-4">Excellent</td>
                    <td class="py-3 px-4">Condition monthly</td>
                  </tr>
                  <tr class="border-b border-gray-100">
                    <td class="py-3 px-4 font-medium">Suede</td>
                    <td class="py-3 px-4">Summer, casual</td>
                    <td class="py-3 px-4">Medium</td>
                    <td class="py-3 px-4">Good</td>
                    <td class="py-3 px-4">Suede brush + spray</td>
                  </tr>
                  <tr class="border-b border-gray-100">
                    <td class="py-3 px-4 font-medium">Nubuck</td>
                    <td class="py-3 px-4">Fall/winter casual</td>
                    <td class="py-3 px-4">Medium</td>
                    <td class="py-3 px-4">Good</td>
                    <td class="py-3 px-4">Nubuck cleaner</td>
                  </tr>
                  <tr class="border-b border-gray-100">
                    <td class="py-3 px-4 font-medium">Exotics (Croc)</td>
                    <td class="py-3 px-4">Statement pieces</td>
                    <td class="py-3 px-4">Very High</td>
                    <td class="py-3 px-4">Excellent</td>
                    <td class="py-3 px-4">Special conditioner</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 font-medium">Velvet</td>
                    <td class="py-3 px-4">Evening/formal</td>
                    <td class="py-3 px-4">Formal</td>
                    <td class="py-3 px-4">Moderate</td>
                    <td class="py-3 px-4">Brush, spot clean</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        {/* Sourcing */}
        <div class="mb-16">
          <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
            <span class="w-8 h-8 bg-primary-100 rounded-lg flex items-center justify-center text-primary-600">4</span>
            Manufacturing & Sourcing
          </h2>
          
          <div class="bg-white rounded-2xl shadow-lg p-8 border border-gray-100">
            <div class="grid md:grid-cols-2 gap-8">
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-4">China Production Regions</h3>
                <div class="space-y-4">
                  <div class="p-4 bg-gray-50 rounded-xl">
                    <h4 class="font-semibold text-gray-900 text-sm">Wenzhou, Zhejiang</h4>
                    <p class="text-gray-600 text-xs mt-1">
                      Loafer specialist region. Moccasin construction expertise. 
                      Good for penny and tassel styles. Budget to mid-range.
                    </p>
                    <p class="text-primary-600 text-xs font-medium mt-2">MOQ: 200 pairs | Lead: 40-55 days</p>
                  </div>
                  <div class="p-4 bg-gray-50 rounded-xl">
                    <h4 class="font-semibold text-gray-900 text-sm">Guangdong (Dongguan)</h4>
                    <p class="text-gray-600 text-xs mt-1">
                      Premium loafer production. Horsebit hardware expertise. 
                      Italian-style fiddle back. Luxury segment.
                    </p>
                    <p class="text-primary-600 text-xs font-medium mt-2">MOQ: 100 pairs | Lead: 50-65 days</p>
                  </div>
                </div>
              </div>
              
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Cost Breakdown (Per Pair)</h3>
                <div class="space-y-3">
                  <div class="flex justify-between items-center py-2 border-b border-gray-100">
                    <span class="text-gray-600 text-sm">Upper Leather</span>
                    <span class="font-semibold text-gray-900">$10.00-25.00</span>
                  </div>
                  <div class="flex justify-between items-center py-2 border-b border-gray-100">
                    <span class="text-gray-600 text-sm">Hardware (bit/strap)</span>
                    <span class="font-semibold text-gray-900">$1.50-5.00</span>
                  </div>
                  <div class="flex justify-between items-center py-2 border-b border-gray-100">
                    <span class="text-gray-600 text-sm">Insole</span>
                    <span class="font-semibold text-gray-900">$2.00-4.00</span>
                  </div>
                  <div class="flex justify-between items-center py-2 border-b border-gray-100">
                    <span class="text-gray-600 text-sm">Outsole</span>
                    <span class="font-semibold text-gray-900">$4.00-10.00</span>
                  </div>
                  <div class="flex justify-between items-center py-2 border-b border-gray-100">
                    <span class="text-gray-600 text-sm">Lining</span>
                    <span class="font-semibold text-gray-900">$2.00-4.00</span>
                  </div>
                  <div class="flex justify-between items-center py-2 border-b border-gray-100">
                    <span class="text-gray-600 text-sm">Assembly</span>
                    <span class="font-semibold text-gray-900">$5.00-15.00</span>
                  </div>
                  <div class="flex justify-between items-center py-3 bg-primary-50 px-4 rounded-lg">
                    <span class="font-semibold text-gray-900">Total FOB (Leather)</span>
                    <span class="font-bold text-primary-600">$25.00-65.00</span>
                  </div>
                  <div class="flex justify-between items-center py-3 bg-secondary-50 px-4 rounded-lg">
                    <span class="font-semibold text-gray-900">Total FOB (Horsebit)</span>
                    <span class="font-bold text-secondary-600">$28.00-70.00</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* Related */}
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Related Categories</h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
    {categories.map(cat => (
      <a href={cat.url} class="bg-white rounded-xl shadow-md p-6 border border-gray-100 hover:shadow-lg hover:border-primary-200 transition-all group">
        <h3 class="font-semibold text-gray-900 group-hover:text-primary-600 transition-colors mb-2">
          {cat.name}
        </h3>
        <p class="text-gray-600 text-sm mb-3">{cat.description}</p>
        <span class="text-primary-600 text-sm font-medium">{cat.count} articles</span>
      </a>
    ))}
  </div>
        </div>

      </div>
    </div>
  </section>
</PageLayout>
