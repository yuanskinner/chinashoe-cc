      links: [
        { label: 'Overview', href: '/encyclopedia/mules/', active: true },
        { label: 'Heel Mules', href: '/encyclopedia/mules/heel-mules/' },
        { label: 'Flat Mules', href: '/encyclopedia/mules/flat-mules/' },
        { label: 'Platform Mules', href: '/encyclopedia/mules/platform-mules/' },
