<PageLayout
  title="Mules Guide"
  description="Complete guide to mules: understanding heeled, flat, and platform styles, construction techniques, fashion history, and manufacturing insights."
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Encyclopedia', url: '/encyclopedia/' },
    { name: 'Categories', url: '/encyclopedia/categories/' },
    { name: 'Mules', url: '/encyclopedia/mules/' },
  ]}
  sidebarItems={[
    {
