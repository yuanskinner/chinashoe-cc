<PageLayout
  title="Running Shoe Cushioning Technologies Guide"
  description="Understanding running shoe cushioning: EVA, PU, Gel, Air, and Foam technologies. Learn how each system works and which is best for your running needs."
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Encyclopedia', url: '/encyclopedia/' },
    { name: 'Running Shoes', url: '/encyclopedia/running-shoes/' },
    { name: 'Cushioning Technologies', href: '/encyclopedia/running-shoes/cushioning/' },
  ]}
  sidebarItems={[
    {
      title: 'Running Shoes',
      links: [
        { label: 'Overview', href: '/encyclopedia/running-shoes/' },
        { label: 'Anatomy', href: '/encyclopedia/running-shoes/anatomy/' },
        { label: 'Cushioning', href: '/encyclopedia/running-shoes/cushioning/', active: true },
        { label: 'Categories', href: '/encyclopedia/running-shoes/categories/' },
        { label: 'Trail Running', href: '/encyclopedia/running-shoes/trail/' },
        { label: 'Racing Flats', href: '/encyclopedia/running-shoes/racing-flats/' },
