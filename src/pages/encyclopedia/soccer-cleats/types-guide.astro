---
import BaseLayout from '@layouts/BaseLayout.astro';
const title = "Soccer Cleats Types Guide: FG, SG, AG, TF, IC — Complete Selection for Every Surface";
const description = "Complete guide to soccer cleat types — FG (Firm Ground), SG (Soft Ground), AG (Artificial Grass), TF (Turf), IC (Indoor Court), and more. Understand stud configurations, outsole materials, upper constructions, and how to choose the right cleat for every playing surface and player position.";
const keywords = "soccer cleats types, football boots guide, FG cleats, SG cleats, AG cleats, turf shoes, indoor soccer shoes, stud configuration, outsole types, soccer shoe selection";
---

<BaseLayout title={title} description={description} keywords={keywords}>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

  <nav class="mb-8 text-sm text-gray-500">
    <a href="/" class="hover:text-primary-600">Home</a>
    <span class="mx-2">/</span>
    <a href="/encyclopedia/" class="hover:text-primary-600">Encyclopedia</a>
    <span class="mx-2">/</span>
    <a href="/encyclopedia/soccer-cleats/" class="hover:text-primary-600">Soccer Cleats</a>
    <span class="mx-2">/</span>
    <span class="text-gray-900 font-medium">Types Guide</span>
  </nav>

  <header class="mb-12">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Soccer Cleats Types Guide</h1>
    <p class="text-xl text-gray-600 leading-relaxed">From <strong>FG firm ground</strong> to <strong>IC indoor court</strong>, every soccer cleat type exists for a reason. This guide covers <strong>stud configurations</strong>, <strong>outsole materials</strong>, <strong>upper constructions</strong>, and the critical relationship between <strong>cleat type and playing surface</strong> — so you never sell the wrong shoe to the wrong player again.</p>
    <div class="mt-6 flex items-center gap-4 text-sm text-gray-500">
      <span>Updated: June 2025</span><span>•</span><span>13 min read</span><span>•</span><span>By ChinaShoe Editorial Team</span>
    </div>
  </header>

  <!-- Surface Decision Tree -->
  <section class="mb-16">
    <h2 class="text-3xl font-bold text-gray-900 mb-6">Which Cleat for Which Surface? — Decision Tree</h2>
    <p class="text-gray-600 mb-6">The single most important factor in <strong>soccer cleat selection</strong> is the <strong>playing surface</strong>. Using the wrong cleat type doesn't just reduce performance — it causes <strong>injury risk</strong> and <strong>premature stud wear</strong>. Follow this decision tree:</p>
    
    <div class="bg-white rounded-xl shadow-lg p-8 mb-8">
      <div class="mermaid">
graph TD
    Start[What surface do you play on?] --> Surface["Surface Type?"]
    
    Surface -->|Natural Grass| Grass["Grass Condition?"]
    Surface -->|Artificial Grass| Arti["Pile Height?"]
    Surface -->|Hard Indoor| Indoor["IC - Indoor Court<br/>Flat gum rubber outsole<br/>Non-marking sole<br/>Herringbone or pivot pattern"]
    Surface -->|Street / Hard Ground| HG["HG - Hard Ground<br/>Short rubber studs<br/>12-16 conical studs<br/>Durable TPU outsole"]
    
    Grass -->|Firm, dry| FG["FG - Firm Ground<br/>10-13 molded studs<br/>Conical + bladed mix<br/>TPU or nylon outsole<br/>Most popular type worldwide"]
    Grass -->|Wet, muddy| SG["SG - Soft Ground<br/>6-8 long metal-tipped studs<br/>Screw-in aluminum<br/>Prevents clogging in mud"]
    Grass -->|Very dry, hard| HG2["HG - Hard Ground<br/>Same as HG above<br/>Short studs prevent jarring"]
    
    Arti -->|Long pile 40-60mm| AG["AG - Artificial Grass<br/>Many short hollow studs<br/>16-20 studs for even pressure<br/>EVA cushioning in midsole"]
    Arti -->|Short pile 20-35mm| TF["TF - Turf<br/>Dense rubber nub pattern<br/>All-over small studs<br/>Extra cushioning layer<br/>Most versatile artificial option"]

    style Start fill:#B91C1C,color:#fff
    style FG fill:#15803D,color:#fff
    style SG fill:#1E40AF,color:#fff
    style AG fill:#92400E,color:#fff
    style TF fill:#7C3AED,color:#fff
    style IC fill:#0369A1,color:#fff
    style HG fill:#BE185D,color:#fff
      </div>
    </div>
  </section>

  <!-- Type-by-Type Deep Dive -->
  <section class="mb-16">
    <h2 class="text-3xl font-bold text-gray-900 mb-6">Cleat Type Deep Dive</h2>

    <!-- FG -->
    <div class="bg-white rounded-xl shadow-md p-8 mb-8">
      <h3 class="text-2xl font-bold text-green-700 mb-4">FG — Firm Ground</h3>
      <p class="text-gray-600 mb-4">The most common soccer cleat type, designed for <strong>natural grass pitches</strong> in <strong>dry to slightly damp</strong> conditions. FG cleats account for approximately <strong>60% of global soccer cleat sales</strong>.</p>
      
      <div class="grid md:grid-cols-2 gap-6 mb-4">
        <div>
          <h4 class="font-semibold text-gray-900 mb-2">Stud Configuration</h4>
          <ul class="space-y-1 text-gray-600 text-sm">
            <li>• <strong>10-13 studs</strong> total</li>
            <li>• Mix of <strong>conical</strong> (pivot) and <strong>bladed</strong> (traction) studs</li>
            <li>• Stud height: <strong>10-14mm</strong></li>
            <li>• Forefoot: 6-8 studs for acceleration</li>
            <li>• Heel: 4 studs for stability</li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold text-gray-900 mb-2">Outsole Material</h4>
          <ul class="space-y-1 text-gray-600 text-sm">
            <li>• <strong>TPU</strong> — standard, durable, $3-6/pair</li>
            <li>• <strong>Nylon/PEBAX</strong> — lightweight, responsive, $6-12/pair</li>
            <li>• <strong>Carbon fiber</strong> — elite, stiff, $15-25/pair</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- SG -->
    <div class="bg-white rounded-xl shadow-md p-8 mb-8">
      <h3 class="text-2xl font-bold text-blue-700 mb-4">SG — Soft Ground</h3>
      <p class="text-gray-600 mb-4">Designed for <strong>wet, muddy natural grass</strong>. SG cleats feature <strong>fewer, longer studs</strong> that penetrate soft ground without clogging. The <strong>aluminum screw-in tips</strong> prevent wear on hard patches.</p>
      
      <div class="grid md:grid-cols-2 gap-6 mb-4">
        <div>
          <h4 class="font-semibold text-gray-900 mb-2">Stud Configuration</h4>
          <ul class="space-y-1 text-gray-600 text-sm">
            <li>• <strong>6 studs</strong> (traditional) or <strong>8 studs</strong> (hybrid)</li>
            <li>• Stud height: <strong>15-18mm</strong></li>
            <li>• <strong>Screw-in aluminum tips</strong> with nylon body</li>
            <li>• Includes 2 spare studs per pair</li>
            <li>• Never use on artificial grass — injury risk</li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold text-gray-900 mb-2">Market Position</h4>
          <ul class="space-y-1 text-gray-600 text-sm">
            <li>• ~<strong>8% of global sales</strong></li>
            <li>• Popular in UK, Northern Europe, South America</li>
            <li>• Higher price point due to metal hardware</li>
            <li>• Many clubs require SG as mandatory option</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- AG -->
    <div class="bg-white rounded-xl shadow-md p-8 mb-8">
      <h3 class="text-2xl font-bold text-amber-700 mb-4">AG — Artificial Grass</h3>
      <p class="text-gray-600 mb-4">Specifically engineered for <strong>3rd/4th generation artificial turf</strong> with <strong>rubber infill</strong>. AG cleats have <strong>more studs</strong> than FG to distribute pressure evenly and prevent <strong>turf toe</strong> and <strong>ACL stress</strong>.</p>
      
      <div class="grid md:grid-cols-2 gap-6 mb-4">
        <div>
          <h4 class="font-semibold text-gray-900 mb-2">Stud Configuration</h4>
          <ul class="space-y-1 text-gray-600 text-sm">
            <li>• <strong>16-20 studs</strong> total</li>
            <li>• Stud height: <strong>6-9mm</strong></li>
            <li>• <strong>Hollow conical studs</strong> for shock absorption</li>
            <li>• Broader stud base to prevent rubber infill clogging</li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold text-gray-900 mb-2">Critical Sourcing Note</h4>
          <ul class="space-y-1 text-gray-600 text-sm">
            <li>• <strong>Fastest growing segment</strong> — 20%+ CAGR</li>
            <li>• Urban markets replacing natural grass</li>
            <li>• China producing 40%+ of world's AG pitches</li>
            <li>• AG-specific outsole molds are a must</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- TF -->
    <div class="bg-white rounded-xl shadow-md p-8 mb-8">
      <h3 class="text-2xl font-bold text-purple-700 mb-4">TF — Turf</h3>
      <p class="text-gray-600 mb-4">For <strong>short-pile artificial turf</strong> or <strong>carpet-style indoor/outdoor</strong> surfaces. TF shoes feature a <strong>dense rubber nub pattern</strong> rather than individual studs, providing all-over grip and superior cushioning.</p>
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <h4 class="font-semibold text-gray-900 mb-2">Design Features</h4>
          <ul class="space-y-1 text-gray-600 text-sm">
            <li>• <strong>Rubber nub outsole</strong> — hundreds of small 2-3mm nubs</li>
            <li>• <strong>EVA midsole</strong> — extra cushioning on hard surfaces</li>
            <li>• <strong>Thicker insole</strong> — Poron or Ortholite cushion</li>
            <li>• Most <strong>versatile</strong> — usable on multiple surfaces</li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold text-gray-900 mb-2">Pricing (FOB China)</h4>
          <ul class="space-y-1 text-gray-600 text-sm">
            <li>• Synthetic upper: <strong>$5-10/pair</strong></li>
            <li>• Leather upper: <strong>$10-18/pair</strong></li>
            <li>• Brand premium: <strong>$15-30/pair</strong></li>
            <li>• Lowest tooling cost — no stud molds needed</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Upper Materials Comparison -->
  <section class="mb-16">
    <h2 class="text-3xl font-bold text-gray-900 mb-6">Upper Material Selection by Position & Price</h2>
    <p class="text-gray-600 mb-6">Soccer cleat uppers have evolved dramatically. The choice between <strong>kangaroo leather</strong>, <strong>synthetic knit</strong>, and <strong>hybrid</strong> affects <strong>touch quality</strong>, <strong>weight</strong>, <strong>water resistance</strong>, and <strong>durability</strong>:</p>
    
    <div class="bg-white rounded-xl shadow-lg p-8 mb-8">
      <div class="mermaid">
graph TD
    Start[Choose Upper Material] --> Position["Player Position?"]
    
    Position -->|Forward / Winger| Speed["Speed Priority<br/>Need: Lightweight, barefoot feel"]
    Position -->|Midfielder| Touch["Touch Priority<br/>Need: Ball control, flexibility"]
    Position -->|Defender| Dur["Durability Priority<br/>Need: Protection, structure"]
    Position -->|Goalkeeper| Grip["Grip Priority<br/>Need: Latex, ball handling"]
    
    Speed --> SynKnit["Synthetic Knit<br/>1-2mm thin upper<br/>Textured coating for grip<br/>150-180g per shoe<br/>e.g., Nike Mercurial, Puma Ultra"]
    Touch --> KLeather["Kangaroo Leather<br/>Natural softness & feel<br/>Molds to foot shape<br/>180-220g per shoe<br/>e.g., Nike Tiempo, Copa Pure"]
    Dur --> Hybrid["Hybrid Upper<br/>Leather forefoot + synthetic heel<br/>Reinforced toe box<br/>220-260g per shoe<br/>e.g., Nike Phantom, Pred Edge"]
    Grip --> GK["Goalkeeper Glove Integration<br/>Latex palm grip zone<br/>Mesh backhand flexibility<br/>e.g., Reusch, Uhlsport"]

    style Start fill:#B91C1C,color:#fff
    style SynKnit fill:#1E40AF,color:#fff
    style KLeather fill:#92400E,color:#fff
    style Hybrid fill:#047857,color:#fff
    style GK fill:#7C3AED,color:#fff
      </div>
    </div>
  </section>

  <!-- Position Guide Table -->
  <section class="mb-16">
    <h2 class="text-3xl font-bold text-gray-900 mb-6">Quick Reference: Cleat Recommendations by Position & Surface</h2>
    <div class="overflow-x-auto mb-8">
      <table class="w-full bg-white rounded-xl shadow-md overflow-hidden text-sm">
        <thead class="bg-primary-600 text-white">
          <tr>
            <th class="px-3 py-3 text-left">Position</th>
            <th class="px-3 py-3 text-left">Firm Ground</th>
            <th class="px-3 py-3 text-left">Soft Ground</th>
            <th class="px-3 py-3 text-left">Artificial Grass</th>
            <th class="px-3 py-3 text-left">Turf</th>
            <th class="px-3 py-3 text-left">Indoor</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <tr class="hover:bg-gray-50">
            <td class="px-3 py-3 font-medium"><strong>Forward</strong></td>
            <td class="px-3 py-3">FG bladed, knit upper</td>
            <td class="px-3 py-3">SG hybrid, knit upper</td>
            <td class="px-3 py-3">AG hollow, knit upper</td>
            <td class="px-3 py-3">TF nub, knit upper</td>
            <td class="px-3 py-3">IC flat, knit upper</td>
          </tr>
          <tr class="hover:bg-gray-50">
            <td class="px-3 py-3 font-medium"><strong>Midfielder</strong></td>
            <td class="px-3 py-3">FG conical, leather upper</td>
            <td class="px-3 py-3">SG 6-stud, leather upper</td>
            <td class="px-3 py-3">AG conical, leather upper</td>
            <td class="px-3 py-3">TF nub, leather upper</td>
            <td class="px-3 py-3">IC flat, leather upper</td>
          </tr>
          <tr class="hover:bg-gray-50">
            <td class="px-3 py-3 font-medium"><strong>Defender</strong></td>
            <td class="px-3 py-3">FG mixed, hybrid upper</td>
            <td class="px-3 py-3">SG 8-stud, hybrid upper</td>
            <td class="px-3 py-3">AG conical, hybrid upper</td>
            <td class="px-3 py-3">TF nub, hybrid upper</td>
            <td class="px-3 py-3">IC flat, hybrid upper</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Related -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Related Articles</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <a href="/encyclopedia/soccer-cleats/" class="bg-white rounded-xl shadow-md p-6 border border-gray-100 hover:shadow-lg hover:border-primary-200 transition-all group">
        <h3 class="font-semibold text-gray-900 group-hover:text-primary-600 transition-colors mb-2">Soccer Cleats Overview</h3>
        <p class="text-gray-600 text-sm">Complete introduction to football boots.</p>
      </a>
      <a href="/encyclopedia/basketball-shoes/" class="bg-white rounded-xl shadow-md p-6 border border-gray-100 hover:shadow-lg hover:border-primary-200 transition-all group">
        <h3 class="font-semibold text-gray-900 group-hover:text-primary-600 transition-colors mb-2">Basketball Shoes Guide</h3>
        <p class="text-gray-600 text-sm">Court-specific athletic footwear comparison.</p>
      </a>
      <a href="/encyclopedia/running-shoes/anatomy-guide/" class="bg-white rounded-xl shadow-md p-6 border border-gray-100 hover:shadow-lg hover:border-primary-200 transition-all group">
        <h3 class="font-semibold text-gray-900 group-hover:text-primary-600 transition-colors mb-2">Running Shoes Anatomy</h3>
        <p class="text-gray-600 text-sm">Athletic shoe structural breakdown.</p>
      </a>
    </div>
  </section>
</div>

</BaseLayout>
