    <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
      Vulcanized Process Guide
    </h1>
    <p class="text-lg text-neutral-600">
      Comprehensive guide to vulcanized footwear construction: understanding the vulcanization chemistry, production process, quality standards, and China manufacturing capabilities.
    </p>
  </div>

  <!-- Featured Image -->
  <div class="rounded-xl overflow-hidden mb-8">
    <img
      src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=1200&h=400&fit=crop"
      alt="Vulcanized Footwear Production"
      class="w-full h-64 md:h-80 object-cover"
    />
  </div>

  <!-- Key Statistics -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
    <div class="card p-6">
      <p class="text-lg text-amber-700 font-medium mb-2">History</p>
      <p class="text-4xl font-bold text-amber-900 mb-2">180+</p>
      <p class="text-base text-gray-500">Years since invention</p>
    </div>
    <div class="card p-6">
      <p class="text-lg text-blue-700 font-medium mb-2">Cure Temp</p>
      <p class="text-4xl font-bold text-blue-900 mb-2">150°C</p>
      <p class="text-base text-gray-500">Typical vulcanization temperature</p>
    </div>
    <div class="card p-6">
      <p class="text-lg text-green-700 font-medium mb-2">Market Share</p>
      <p class="text-4xl font-bold text-green-900 mb-2">25<span class="text-lg ml-1">%</span></p>
