---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 - Page Not Found"
  description="The page you're looking for doesn't exist."
  noindex={true}
>
  <section class="min-h-[60vh] flex items-center justify-center">
    <div class="container-custom py-16 text-center">
      <div class="max-w-xl mx-auto">
        <span class="text-8xl font-bold text-primary-200">404</span>
        <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
          Page Not Found
        </h1>
        <p class="text-lg text-neutral-600 mb-8">
          Sorry, the page you're looking for doesn't exist or has been moved.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/" class="btn-primary">
            Go to Homepage
          </a>
          <a href="/contact/" class="btn-secondary">
            Contact Us
          </a>
        </div>
        
        <div class="mt-12 pt-8 border-t border-neutral-200">
          <h2 class="font-semibold text-neutral-900 mb-4">Popular Pages</h2>
          <div class="flex flex-wrap justify-center gap-3">
            <a href="/encyclopedia/" class="badge-primary">Encyclopedia</a>
            <a href="/suppliers/" class="badge-primary">Suppliers</a>
            <a href="/news/" class="badge-primary">News</a>
            <a href="/sourcing/" class="badge-primary">Sourcing Guide</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
