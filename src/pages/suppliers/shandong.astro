---
import PageLayout from '@layouts/PageLayout.astro';

const suppliers = [
  {
    name: 'Qingdao Safety First Industrial Co.',
    location: 'Qingdao',
    specialization: ['Safety Shoes', 'Work Boots', 'Steel Toe Cap Shoes'],
    moq: '500 pairs',
    href: '/suppliers/qingdao-safety-first/',
  },
];

const cities = [
  { name: 'Qingdao', description: 'Safety shoes and industrial footwear hub with direct port access', count: 340 },
  { name: 'Weifang', description: 'PU and chemical-resistant footwear manufacturing', count: 85 },
  { name: 'Linyi', description: 'Budget safety shoes and rubber boots production', count: 120 },
  { name: 'Jinan', description: 'Military and tactical footwear manufacturing', count: 45 },
];
---

<PageLayout
  title="Shandong Footwear Suppliers"
  description="Find verified safety shoe and work boot manufacturers in Shandong Province. CE EN ISO 20345 and ASTM F2413 certified factories with direct port access via Qingdao."
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Suppliers', url: '/suppliers/' },
    { name: 'Shandong', url: '/suppliers/shandong/' },
  ]}
>
  <div class="mb-8">
    <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
      Shandong Footwear Suppliers
    </h1>
    <p class="text-lg text-neutral-600 max-w-3xl">
      Shandong Province is <strong>China's leading hub for safety and industrial footwear</strong>. With <strong>540+ registered manufacturers</strong>, the region specializes in steel-toe boots, composite-toe shoes, and certified protective footwear. Qingdao port provides direct export access to global markets.
    </p>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
    <div class="bg-primary-50 rounded-lg p-4 text-center">
      <div class="text-2xl font-bold text-primary-600">540+</div>
      <div class="text-sm text-neutral-600">Manufacturers</div>
    </div>
    <div class="bg-primary-50 rounded-lg p-4 text-center">
      <div class="text-2xl font-bold text-primary-600">15M+</div>
      <div class="text-sm text-neutral-600">Annual Pairs</div>
    </div>
    <div class="bg-primary-50 rounded-lg p-4 text-center">
      <div class="text-2xl font-bold text-primary-600">EN 20345</div>
      <div class="text-sm text-neutral-600">CE Certified</div>
    </div>
    <div class="bg-primary-50 rounded-lg p-4 text-center">
      <div class="text-2xl font-bold text-primary-600">ASTM</div>
      <div class="text-sm text-neutral-600">US Standard</div>
    </div>
  </div>

  <div class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-6">Featured Suppliers</h2>
    <div class="grid md:grid-cols-2 gap-6">
      {suppliers.map(supplier => (
        <a href={supplier.href} class="card group">
          <h3 class="font-semibold text-lg text-neutral-900 group-hover:text-primary-600 transition-colors mb-2">{supplier.name}</h3>
          <div class="flex items-center gap-2 text-sm text-neutral-500 mb-3">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {supplier.location}
          </div>
          <div class="flex flex-wrap gap-1 mb-3">
            {supplier.specialization.map(spec => (
              <span class="text-xs px-2 py-0.5 bg-neutral-100 text-neutral-600 rounded">{spec}</span>
            ))}
          </div>
          <span class="text-sm text-neutral-500">MOQ: {supplier.moq}</span>
        </a>
      ))}
    </div>
  </div>

  <div class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-6">Production Cities</h2>
    <div class="grid md:grid-cols-2 gap-4">
      {cities.map(city => (
        <div class="card border border-transparent">
          <h3 class="font-semibold text-neutral-900 mb-1">{city.name}</h3>
          <p class="text-sm text-neutral-600 mb-2">{city.description}</p>
          <span class="text-xs text-primary-600 font-medium">{city.count} suppliers</span>
        </div>
      ))}
    </div>
  </div>

  <div class="bg-primary-50 rounded-xl p-8 text-center">
    <h3 class="text-xl font-bold text-neutral-900 mb-2">Need a Safety Footwear Supplier?</h3>
    <p class="text-neutral-600 mb-4">Let us connect you with CE and ASTM certified manufacturers in Shandong.</p>
    <a href="/contact/" class="btn-primary">Contact Us</a>
  </div>
</PageLayout>
