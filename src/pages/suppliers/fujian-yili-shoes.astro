---
import PageLayout from '@layouts/PageLayout.astro';

const products = [
  { name: 'Running Shoes', moq: '500 pairs', leadTime: '35-45 days' },
  { name: 'Basketball Shoes', moq: '300 pairs', leadTime: '40-50 days' },
  { name: 'Casual Sneakers', moq: '500 pairs', leadTime: '30-40 days' },
  { name: 'Training Shoes', moq: '500 pairs', leadTime: '35-45 days' },
  { name: 'Kids Athletic Shoes', moq: '800 pairs', leadTime: '30-40 days' },
];

const certifications = [
  { name: 'BSCI', description: 'Business Social Compliance Initiative' },
  { name: 'ISO 9001', description: 'Quality Management System' },
  { name: 'SEDEX', description: 'Supplier Ethical Data Exchange' },
];

const capabilities = [
  { name: 'Flyknit Upper', description: 'Computerized flat knitting for seamless uppers' },
  { name: 'Injection Midsole', description: 'EVA/TPU injection for responsive cushioning' },
  { name: 'Rubber Outsole Molding', description: 'Custom outsole design and rubber compounding' },
  { name: 'Sublimation Printing', description: 'Full-color upper pattern printing technology' },
];
---

<PageLayout
  title="Fujian Yili Shoes Co., Ltd. - Athletic Footwear Manufacturer"
  description="Verified supplier profile for Fujian Yili Shoes, a professional athletic footwear manufacturer in Jinjiang, Fujian. Specializing in running shoes, basketball shoes, and casual sneakers with flyknit and injection midsole capabilities."
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Suppliers', url: '/suppliers/' },
    { name: 'Fujian', url: '/suppliers/' },
    { name: 'Fujian Yili Shoes', url: '/suppliers/fujian-yili-shoes/' },
  ]}
>
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="badge-success">Verified Supplier</span>
      <span class="badge-primary">Athletic Footwear</span>
    </div>
    <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
      Fujian Yili Shoes Co., Ltd.
    </h1>
    <p class="text-lg text-neutral-600">
      Professional athletic footwear manufacturer based in **Jinjiang, Fujian Province** — China's largest sport shoe production hub. Specializing in **running shoes**, **basketball shoes**, and **casual sneakers** with integrated flyknit and injection midsole production lines.
    </p>
  </div>

  <div class="rounded-xl overflow-hidden mb-8">
    <img src="/images/suppliers/fujian-yili.jpg" alt="Fujian Yili Shoes Athletic Footwear" class="w-full h-64 md:h-80 object-cover" />
  </div>

  <div class="grid md:grid-cols-4 gap-6 mb-12">
    <div class="card text-center">
      <div class="text-2xl font-bold text-primary-600 mb-1">Jinjiang</div>
      <div class="text-sm text-neutral-500">Location</div>
    </div>
    <div class="card text-center">
      <div class="text-2xl font-bold text-primary-600 mb-1">2010</div>
      <div class="text-sm text-neutral-500">Established</div>
    </div>
    <div class="card text-center">
      <div class="text-2xl font-bold text-primary-600 mb-1">1.2M</div>
      <div class="text-sm text-neutral-500">Annual Capacity</div>
    </div>
    <div class="card text-center">
      <div class="text-2xl font-bold text-primary-600 mb-1">80+</div>
      <div class="text-sm text-neutral-500">Brand Partners</div>
    </div>
  </div>

  <div class="prose prose-lg max-w-none mb-12">
    <h2>Company Overview</h2>
    <p>Fujian Yili Shoes Co., Ltd. operates from the heart of China's athletic footwear manufacturing cluster in <strong>Jinjiang, Fujian</strong>. With over a decade of OEM/ODM experience, the factory has built a strong reputation for delivering <strong>high-performance athletic shoes</strong> at competitive pricing, serving brands across Europe, North America, and Southeast Asia.</p>
    <p>The facility spans <strong>8,000 square meters</strong> with 4 production lines capable of producing over <strong>100,000 pairs per month</strong>. The company has invested heavily in <strong>flyknit technology</strong> and <strong>automated injection molding equipment</strong>, enabling rapid prototyping and consistent quality at scale.</p>

    <h2>Product Catalog</h2>
    <div class="overflow-x-auto">
      <table class="min-w-full border border-neutral-200 rounded-lg overflow-hidden">
        <thead class="bg-neutral-50">
          <tr>
            <th class="px-4 py-3 text-left text-sm font-semibold text-neutral-700">Product Category</th>
            <th class="px-4 py-3 text-left text-sm font-semibold text-neutral-700">MOQ</th>
            <th class="px-4 py-3 text-left text-sm font-semibold text-neutral-700">Lead Time</th>
            <th class="px-4 py-3 text-left text-sm font-semibold text-neutral-700">FOB Price Range</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-neutral-100">
          {products.map(p => (
            <tr class="hover:bg-neutral-50">
              <td class="px-4 py-3 text-sm font-medium text-neutral-900">{p.name}</td>
              <td class="px-4 py-3 text-sm text-neutral-600">{p.moq}</td>
              <td class="px-4 py-3 text-sm text-neutral-600">{p.leadTime}</td>
              <td class="px-4 py-3 text-sm text-neutral-600">$8 – $18 / pair</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <h2>Manufacturing Capabilities</h2>
    <div class="grid md:grid-cols-2 gap-4 not-prose">
      {capabilities.map(c => (
        <div class="bg-white border border-neutral-200 rounded-lg p-4">
          <h3 class="font-semibold text-neutral-900 mb-1">{c.name}</h3>
          <p class="text-sm text-neutral-600">{c.description}</p>
        </div>
      ))}
    </div>

    <h2>Quality Control</h2>
    <p>Every production batch undergoes a <strong>3-stage quality inspection</strong> process: incoming material inspection (IMI), in-line production check (ILC), and final random inspection (FRI) per <strong>AQL 2.5 standard</strong>. The laboratory is equipped with <strong>satra testing equipment</strong> for flex resistance, abrasion, and colorfastness testing.</p>

    <h3>Key Quality Metrics</h3>
    <ul>
      <li><strong>Outsole abrasion resistance</strong>: ≤ 120mm³ volume loss (DIN standard)</li>
      <li><strong>Upper flex resistance</strong>: ≥ 50,000 cycles without cracking</li>
      <li><strong>Sole bond strength</strong>: ≥ 2.5 N/mm (cemented), ≥ 3.0 N/mm (injection)</li>
      <li><strong>Colorfastness to rubbing</strong>: Grade 4+ (dry), Grade 3+ (wet)</li>
    </ul>

    <h2>Market & Export</h2>
    <div class="grid md:grid-cols-3 gap-4 not-prose">
      <div class="bg-primary-50 border border-primary-100 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary-600">40%</div>
        <div class="text-sm text-neutral-600">North America</div>
      </div>
      <div class="bg-primary-50 border border-primary-100 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary-600">30%</div>
        <div class="text-sm text-neutral-600">Europe</div>
      </div>
      <div class="bg-primary-50 border border-primary-100 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary-600">30%</div>
        <div class="text-sm text-neutral-600">Asia & Others</div>
      </div>
    </div>

    <h2>Certifications</h2>
    <div class="flex flex-wrap gap-3 not-prose">
      {certifications.map(c => (
        <div class="bg-green-50 border border-green-200 rounded-lg px-4 py-2">
          <div class="font-semibold text-green-800 text-sm">{c.name}</div>
          <div class="text-xs text-green-600">{c.description}</div>
        </div>
      ))}
    </div>

    <h2>Contact Information</h2>
    <div class="bg-neutral-50 rounded-lg p-6 not-prose">
      <div class="grid md:grid-cols-2 gap-4">
        <div>
          <p class="text-sm text-neutral-500">Address</p>
          <p class="font-medium text-neutral-900">Jinjiang Economic Development Zone, Quanzhou, Fujian, China</p>
        </div>
        <div>
          <p class="text-sm text-neutral-500">Business Type</p>
          <p class="font-medium text-neutral-900">Manufacturer (OEM/ODM)</p>
        </div>
        <div>
          <p class="text-sm text-neutral-500">Employees</p>
          <p class="font-medium text-neutral-900">150 – 200</p>
        </div>
        <div>
          <p class="text-sm text-neutral-500">Annual Revenue</p>
          <p class="font-medium text-neutral-900">US$5M – US$10M</p>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-primary-600 text-white rounded-xl p-8 text-center">
    <h3 class="text-2xl font-bold mb-3">Ready to Source from Fujian Yili?</h3>
    <p class="mb-6 text-primary-100">Get connected with verified athletic footwear manufacturers in Fujian Province.</p>
    <a href="/contact/" class="inline-block bg-white text-primary-600 font-semibold px-8 py-3 rounded-lg hover:bg-primary-50 transition-colors">Contact Us for Introduction</a>
  </div>
</PageLayout>
