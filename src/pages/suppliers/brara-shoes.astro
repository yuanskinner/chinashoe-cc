---
import PageLayout from '@layouts/PageLayout.astro';

const products = [
  { name: "Women's Fashion Shoes", moq: '300 pairs', leadTime: '30-45 days' },
  { name: "Women's Sandals", moq: '500 pairs', leadTime: '25-35 days' },
  { name: "Women's Leather Shoes", moq: '200 pairs', leadTime: '35-50 days' },
  { name: "Women's High Heels", moq: '300 pairs', leadTime: '30-45 days' },
  { name: "Women's Casual Shoes", moq: '500 pairs', leadTime: '25-35 days' },
  { name: "Women's Boots", moq: '200 pairs', leadTime: '40-55 days' },
  { name: "Women's Customized Shoes", moq: '100 pairs', leadTime: '45-60 days' },
  { name: "Clothing & Bags", moq: '500 pcs', leadTime: '25-35 days' },
];

const capabilities = [
  { name: 'In-House Design Team', description: 'Dedicated R&D team with seasonal collection development, creating 40+ new styles per season based on European and American trend forecasting' },
  { name: 'Full OEM/ODM Service', description: 'Complete turnkey service from sketch to shipment, including material procurement, pattern making, sample development, and bulk production' },
  { name: 'Small-Batch Customization', description: 'Flexible MOQ from 100 pairs for custom designs, supporting boutique brands, limited editions, and market testing runs' },
  { name: 'Quality Control System', description: 'In-line QC at every production stage with pre-shipment inspection, AQL 2.5 standard, and photo/video documentation for remote buyers' },
];
---

<PageLayout
  title="BRARA Shoes - Chengdu Women's Fashion Footwear Manufacturer"
  description="Verified supplier: Chengdu Meijiali Shoes Co., Ltd. (BRARA Shoes). Professional women's shoes manufacturer with 10+ years experience, 8 years Alibaba Gold Supplier, serving Western Europe and North America."
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Suppliers', url: '/suppliers/' },
    { name: 'Sichuan', url: '/suppliers/sichuan/' },
    { name: 'BRARA Shoes', url: '/suppliers/brara-shoes/' },
  ]}
>
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="badge-primary">Women's Fashion</span>
      <span class="inline-block px-3 py-1 bg-amber-100 text-amber-700 text-sm font-medium rounded-full">Alibaba Verified</span>
      <span class="inline-block px-3 py-1 bg-yellow-100 text-yellow-700 text-sm font-medium rounded-full">8 Years Gold Supplier</span>
      <span class="inline-block px-3 py-1 bg-green-100 text-green-700 text-sm font-medium rounded-full">1,000+ Transactions</span>
    </div>
    <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-2">
      BRARA Shoes
    </h1>
    <p class="text-neutral-500 mb-4">Chengdu Meijiali Shoes Co., Ltd.</p>
    <p class="text-lg text-neutral-600">
      Professional women's fashion footwear manufacturer with over 10 years of industry experience and 8 years as an Alibaba Gold Supplier. Specializing in high-quality ladies' shoes for the European and North American markets.
    </p>
  </div>

  <!-- Quick Info Cards -->
  <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-12">
    <div class="bg-white rounded-xl border border-neutral-200 p-4 text-center">
      <div class="text-xl font-bold text-primary-600 mb-1">Chengdu</div>
      <div class="text-xs text-neutral-500">Sichuan, China</div>
    </div>
    <div class="bg-white rounded-xl border border-neutral-200 p-4 text-center">
      <div class="text-xl font-bold text-primary-600 mb-1">2017</div>
      <div class="text-xs text-neutral-500">Established</div>
    </div>
    <div class="bg-white rounded-xl border border-neutral-200 p-4 text-center">
      <div class="text-xl font-bold text-primary-600 mb-1">5-10</div>
      <div class="text-xs text-neutral-500">Employees</div>
    </div>
    <div class="bg-white rounded-xl border border-neutral-200 p-4 text-center">
      <div class="text-xl font-bold text-primary-600 mb-1">$2.5-5M</div>
      <div class="text-xs text-neutral-500">Annual Revenue</div>
    </div>
    <div class="bg-white rounded-xl border border-neutral-200 p-4 text-center">
      <div class="text-xl font-bold text-primary-600 mb-1">1,000+</div>
      <div class="text-xs text-neutral-500">Transactions</div>
    </div>
  </div>

  <!-- Company Overview -->
  <div class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Company Overview</h2>
    <div class="bg-white rounded-xl border border-neutral-200 p-6 md:p-8">
      <p class="text-neutral-600 leading-relaxed mb-4">
        BRARA Shoes (Chengdu Meijiali Shoes Co., Ltd.) is a professional women's shoe manufacturer established for over ten years. The company has built a strong reputation for designing, developing, and manufacturing high-quality ladies' fashion shoes with its own dedicated design team.
      </p>
      <p class="text-neutral-600 leading-relaxed mb-4">
        As an 8-year Alibaba Gold Supplier with 1,000+ completed transactions, BRARA has demonstrated consistent reliability in international trade. The company's deep roots in Chengdu's women's shoe ecosystem provide access to premium local materials — especially Sichuan-sourced leather — and skilled craftsmanship that the region is known for worldwide.
      </p>
      <p class="text-neutral-600 leading-relaxed">
        BRARA's product range covers the full spectrum of women's footwear: fashion shoes, sandals, leather shoes, high heels, casual shoes, customized designs, and boots. With hundreds of styles to choose from, the company serves a diverse global clientele with its primary markets in Western Europe (45%), North America (30%), and Oceania (10%).
      </p>
    </div>
  </div>

  <!-- Market Distribution -->
  <div class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Market Distribution</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-white rounded-xl border border-neutral-200 p-6">
        <div class="flex items-center justify-between mb-2">
          <span class="font-semibold text-neutral-900">Western Europe</span>
          <span class="text-primary-600 font-bold">45%</span>
        </div>
        <div class="w-full bg-neutral-100 rounded-full h-3">
          <div class="bg-primary-600 h-3 rounded-full" style="width: 45%"></div>
        </div>
        <p class="text-sm text-neutral-500 mt-2">Germany, France, UK, Netherlands — Premium fashion shoes</p>
      </div>
      <div class="bg-white rounded-xl border border-neutral-200 p-6">
        <div class="flex items-center justify-between mb-2">
          <span class="font-semibold text-neutral-900">North America</span>
          <span class="text-primary-600 font-bold">30%</span>
        </div>
        <div class="w-full bg-neutral-100 rounded-full h-3">
          <div class="bg-primary-600 h-3 rounded-full" style="width: 30%"></div>
        </div>
        <p class="text-sm text-neutral-500 mt-2">USA, Canada — Boots, casual shoes</p>
      </div>
      <div class="bg-white rounded-xl border border-neutral-200 p-6">
        <div class="flex items-center justify-between mb-2">
          <span class="font-semibold text-neutral-900">Oceania</span>
          <span class="text-primary-600 font-bold">10%</span>
        </div>
        <div class="w-full bg-neutral-100 rounded-full h-3">
          <div class="bg-primary-600 h-3 rounded-full" style="width: 10%"></div>
        </div>
        <p class="text-sm text-neutral-500 mt-2">Australia, New Zealand — Sandals, casual</p>
      </div>
    </div>
  </div>

  <!-- Product Range -->
  <div class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Product Range</h2>
    <div class="grid md:grid-cols-2 gap-4">
      {products.map(product => (
        <div class="bg-white rounded-xl border border-neutral-200 p-5 flex items-center justify-between">
          <div>
            <h3 class="font-semibold text-neutral-900">{product.name}</h3>
            <p class="text-sm text-neutral-500">Lead: {product.leadTime}</p>
          </div>
          <div class="text-right">
            <div class="text-sm text-primary-600 font-medium">MOQ</div>
            <div class="text-sm text-neutral-900 font-semibold">{product.moq}</div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Manufacturing Capabilities -->
  <div class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Manufacturing Capabilities</h2>
    <div class="grid md:grid-cols-2 gap-6">
      {capabilities.map(cap => (
        <div class="bg-white rounded-xl border border-neutral-200 p-6">
          <h3 class="font-bold text-neutral-900 mb-2">{cap.name}</h3>
          <p class="text-neutral-600 text-sm">{cap.description}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Performance Metrics -->
  <div class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Supplier Performance</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-green-50 rounded-xl border border-green-200 p-6 text-center">
        <div class="text-3xl font-bold text-green-600 mb-1">95.65%</div>
        <div class="text-sm text-neutral-600">Response Rate</div>
      </div>
      <div class="bg-green-50 rounded-xl border border-green-200 p-6 text-center">
        <div class="text-3xl font-bold text-green-600 mb-1">≤5h</div>
        <div class="text-sm text-neutral-600">Response Time</div>
      </div>
      <div class="bg-blue-50 rounded-xl border border-blue-200 p-6 text-center">
        <div class="text-3xl font-bold text-blue-600 mb-1">1,000+</div>
        <div class="text-sm text-neutral-600">Transactions</div>
      </div>
    </div>
  </div>

  <!-- Comparison with Regional Peers -->
  <div class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Why Choose BRARA Shoes?</h2>
    <div class="bg-white rounded-xl border border-neutral-200 p-6 md:p-8">
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <h3 class="font-bold text-neutral-900 mb-3 flex items-center gap-2">
            <span class="w-6 h-6 bg-green-100 text-green-600 rounded-full flex items-center justify-center text-sm">✓</span>
            Strengths
          </h3>
          <ul class="space-y-2 text-neutral-600 text-sm">
            <li class="flex items-start gap-2"><span class="text-green-500 mt-0.5">•</span> 8-year track record on Alibaba with 1,000+ transactions</li>
            <li class="flex items-start gap-2"><span class="text-green-500 mt-0.5">•</span> Strong Western European market presence (45%)</li>
            <li class="flex items-start gap-2"><span class="text-green-500 mt-0.5">•</span> Higher annual revenue ($2.5-5M) indicates production capacity</li>
            <li class="flex items-start gap-2"><span class="text-green-500 mt-0.5">•</span> In-house design team with seasonal collections</li>
            <li class="flex items-start gap-2"><span class="text-green-500 mt-0.5">•</span> Flexible MOQ for custom designs</li>
          </ul>
        </div>
        <div>
          <h3 class="font-bold text-neutral-900 mb-3 flex items-center gap-2">
            <span class="w-6 h-6 bg-amber-100 text-amber-600 rounded-full flex items-center justify-center text-sm">!</span>
            Considerations
          </h3>
          <ul class="space-y-2 text-neutral-600 text-sm">
            <li class="flex items-start gap-2"><span class="text-amber-500 mt-0.5">•</span> Small team size (5-10 employees) — may limit capacity for very large orders</li>
            <li class="flex items-start gap-2"><span class="text-amber-500 mt-0.5">•</span> Trading company model — not a direct factory</li>
            <li class="flex items-start gap-2"><span class="text-amber-500 mt-0.5">•</span> No customer reviews yet on Alibaba profile</li>
            <li class="flex items-start gap-2"><span class="text-amber-500 mt-0.5">•</span> Response time (≤5h) slower than premium suppliers</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Contact Section -->
  <div class="bg-neutral-900 rounded-xl p-8 text-white">
    <h3 class="text-2xl font-bold mb-3">Contact BRARA Shoes</h3>
    <p class="text-neutral-300 mb-6">Reach out directly to discuss your sourcing requirements for women's fashion footwear.</p>
    <div class="flex flex-wrap gap-4 mb-6">
      <a href="https://brarashoes.en.alibaba.com/company_profile.html" target="_blank" rel="noopener noreferrer" class="inline-block px-6 py-3 bg-white text-neutral-900 font-semibold rounded-lg hover:bg-neutral-100 transition-colors">View on Alibaba</a>
      <a href="/contact/" class="inline-block px-6 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white/10 transition-colors">Contact via ChinaShoe</a>
    </div>
    <p class="text-neutral-400 text-sm">Chengdu Meijiali Shoes Co., Ltd. | Sichuan, China | Trading Company | Est. 2017</p>
  </div>
</PageLayout>
