---
import PageLayout from '@layouts/PageLayout.astro';

const products = [
  { name: "Women's Fashion Shoes", moq: '300 pairs', leadTime: '30-45 days' },
  { name: "Women's Sandals", moq: '500 pairs', leadTime: '25-35 days' },
  { name: "Women's Leather Shoes", moq: '200 pairs', leadTime: '35-50 days' },
  { name: "Women's High Heels", moq: '300 pairs', leadTime: '30-45 days' },
  { name: "Women's Casual Shoes", moq: '500 pairs', leadTime: '25-35 days' },
  { name: "Women's Boots", moq: '200 pairs', leadTime: '40-55 days' },
  { name: "Women's Customized Shoes", moq: '100 pairs', leadTime: '45-60 days' },
  { name: "Bags & Accessories", moq: '500 pcs', leadTime: '25-35 days' },
];

const capabilities = [
  { name: 'In-House Design Team', description: 'Dedicated R&D team creating 50+ new styles per season based on trend analysis and client briefs' },
  { name: 'Custom OEM/ODM', description: 'Full service from concept sketch to finished product, including material sourcing and pattern engineering' },
  { name: 'Small-Batch Production', description: 'Flexible MOQ starting from 100 pairs for custom designs, ideal for boutique brands and market testing' },
  { name: 'Multi-Material Expertise', description: 'Leather, PU, fabric, and mixed-media constructions with consistent quality across material types' },
];
---

<PageLayout
  title="BALAA Shoe - Chengdu Women's Fashion Footwear Manufacturer"
  description="Verified supplier: Chengdu Wen Zhong Xiang Hao International Trade Co., Ltd. (BALAA Shoe). Professional women's shoes manufacturer with 10+ years experience in fashion shoes, sandals, heels, and boots."
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Suppliers', url: '/suppliers/' },
    { name: 'Sichuan', url: '/suppliers/sichuan/' },
    { name: 'BALAA Shoe', url: '/suppliers/balaa-shoe/' },
  ]}
>
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="badge-primary">Women's Fashion</span>
      <span class="inline-block px-3 py-1 bg-amber-100 text-amber-700 text-sm font-medium rounded-full">Alibaba Verified</span>
      <span class="inline-block px-3 py-1 bg-blue-100 text-blue-700 text-sm font-medium rounded-full">2 Years Gold Supplier</span>
    </div>
    <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-2">
      BALAA Shoe
    </h1>
    <p class="text-neutral-500 mb-4">Chengdu Wen Zhong Xiang Hao International Trade Co., Ltd.</p>
    <p class="text-lg text-neutral-600">
      Professional women's fashion footwear manufacturer with over 10 years of experience in designing, developing, and manufacturing high-quality ladies' shoes. Based in Chengdu, Sichuan — China's women's shoe capital.
    </p>
  </div>

  <!-- Quick Info Cards -->
  <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-12">
    <div class="bg-white rounded-xl border border-neutral-200 p-4 text-center">
      <div class="text-xl font-bold text-primary-600 mb-1">Chengdu</div>
      <div class="text-xs text-neutral-500">Sichuan, China</div>
    </div>
    <div class="bg-white rounded-xl border border-neutral-200 p-4 text-center">
      <div class="text-xl font-bold text-primary-600 mb-1">2024</div>
      <div class="text-xs text-neutral-500">Alibaba Registered</div>
    </div>
    <div class="bg-white rounded-xl border border-neutral-200 p-4 text-center">
      <div class="text-xl font-bold text-primary-600 mb-1">11-50</div>
      <div class="text-xs text-neutral-500">Employees</div>
    </div>
    <div class="bg-white rounded-xl border border-neutral-200 p-4 text-center">
      <div class="text-xl font-bold text-primary-600 mb-1">$1-2.5M</div>
      <div class="text-xs text-neutral-500">Annual Revenue</div>
    </div>
    <div class="bg-white rounded-xl border border-neutral-200 p-4 text-center">
      <div class="text-xl font-bold text-primary-600 mb-1">4.1/5</div>
      <div class="text-xs text-neutral-500">Rating (6 Reviews)</div>
    </div>
  </div>

  <!-- Company Overview -->
  <div class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Company Overview</h2>
    <div class="bg-white rounded-xl border border-neutral-200 p-6 md:p-8">
      <p class="text-neutral-600 leading-relaxed mb-4">
        BALAA Shoe (Chengdu Wen Zhong Xiang Hao International Trade Co., Ltd.) is a professional women's shoe manufacturer with over a decade of industry experience. The company specializes in designing, developing, and manufacturing high-quality ladies' fashion shoes with its own in-house design team.
      </p>
      <p class="text-neutral-600 leading-relaxed mb-4">
        Located in Chengdu — the heart of China's women's footwear industry — BALAA leverages deep local supply chain networks to offer competitive pricing without compromising quality. The company produces a wide range of women's footwear including fashion shoes, sandals, leather shoes, high heels, casual shoes, and boots, with customization capabilities for boutique brands.
      </p>
      <p class="text-neutral-600 leading-relaxed">
        With hundreds of styles available for global customers, BALAA serves markets in North America (30%), Southern Europe (20%), and Western Europe (20%). Their 100% response rate and ≤2 hour average response time reflect their commitment to responsive customer service.
      </p>
    </div>
  </div>

  <!-- Market Distribution -->
  <div class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Market Distribution</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-white rounded-xl border border-neutral-200 p-6">
        <div class="flex items-center justify-between mb-2">
          <span class="font-semibold text-neutral-900">North America</span>
          <span class="text-primary-600 font-bold">30%</span>
        </div>
        <div class="w-full bg-neutral-100 rounded-full h-3">
          <div class="bg-primary-600 h-3 rounded-full" style="width: 30%"></div>
        </div>
        <p class="text-sm text-neutral-500 mt-2">USA, Canada — Fashion shoes, boots</p>
      </div>
      <div class="bg-white rounded-xl border border-neutral-200 p-6">
        <div class="flex items-center justify-between mb-2">
          <span class="font-semibold text-neutral-900">Southern Europe</span>
          <span class="text-primary-600 font-bold">20%</span>
        </div>
        <div class="w-full bg-neutral-100 rounded-full h-3">
          <div class="bg-primary-600 h-3 rounded-full" style="width: 20%"></div>
        </div>
        <p class="text-sm text-neutral-500 mt-2">Italy, Spain, Portugal — Leather shoes, sandals</p>
      </div>
      <div class="bg-white rounded-xl border border-neutral-200 p-6">
        <div class="flex items-center justify-between mb-2">
          <span class="font-semibold text-neutral-900">Western Europe</span>
          <span class="text-primary-600 font-bold">20%</span>
        </div>
        <div class="w-full bg-neutral-100 rounded-full h-3">
          <div class="bg-primary-600 h-3 rounded-full" style="width: 20%"></div>
        </div>
        <p class="text-sm text-neutral-500 mt-2">Germany, France, UK — High heels, casual</p>
      </div>
    </div>
  </div>

  <!-- Product Range -->
  <div class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Product Range</h2>
    <div class="grid md:grid-cols-2 gap-4">
      {products.map(product => (
        <div class="bg-white rounded-xl border border-neutral-200 p-5 flex items-center justify-between">
          <div>
            <h3 class="font-semibold text-neutral-900">{product.name}</h3>
            <p class="text-sm text-neutral-500">Lead: {product.leadTime}</p>
          </div>
          <div class="text-right">
            <div class="text-sm text-primary-600 font-medium">MOQ</div>
            <div class="text-sm text-neutral-900 font-semibold">{product.moq}</div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Manufacturing Capabilities -->
  <div class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Manufacturing Capabilities</h2>
    <div class="grid md:grid-cols-2 gap-6">
      {capabilities.map(cap => (
        <div class="bg-white rounded-xl border border-neutral-200 p-6">
          <h3 class="font-bold text-neutral-900 mb-2">{cap.name}</h3>
          <p class="text-neutral-600 text-sm">{cap.description}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Performance Metrics -->
  <div class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Supplier Performance</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-green-50 rounded-xl border border-green-200 p-6 text-center">
        <div class="text-3xl font-bold text-green-600 mb-1">100%</div>
        <div class="text-sm text-neutral-600">Response Rate</div>
      </div>
      <div class="bg-green-50 rounded-xl border border-green-200 p-6 text-center">
        <div class="text-3xl font-bold text-green-600 mb-1">≤2h</div>
        <div class="text-sm text-neutral-600">Response Time</div>
      </div>
      <div class="bg-amber-50 rounded-xl border border-amber-200 p-6 text-center">
        <div class="text-3xl font-bold text-amber-600 mb-1">4.1/5</div>
        <div class="text-sm text-neutral-600">Customer Rating</div>
      </div>
    </div>
  </div>

  <!-- Contact Section -->
  <div class="bg-neutral-900 rounded-xl p-8 text-white">
    <h3 class="text-2xl font-bold mb-3">Contact BALAA Shoe</h3>
    <p class="text-neutral-300 mb-6">Reach out directly to discuss your sourcing requirements for women's fashion footwear.</p>
    <div class="flex flex-wrap gap-4 mb-6">
      <a href="https://balaashoe.en.alibaba.com/company_profile.html" target="_blank" rel="noopener noreferrer" class="inline-block px-6 py-3 bg-white text-neutral-900 font-semibold rounded-lg hover:bg-neutral-100 transition-colors">View on Alibaba</a>
      <a href="/contact/" class="inline-block px-6 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white/10 transition-colors">Contact via ChinaShoe</a>
    </div>
    <p class="text-neutral-400 text-sm">Chengdu Wen Zhong Xiang Hao International Trade Co., Ltd. | Sichuan, China | Trading Company</p>
  </div>
</PageLayout>
