---
import PageLayout from '@layouts/PageLayout.astro';

const products = [
  { name: 'Steel Toe Safety Boots', moq: '300 pairs', leadTime: '35-45 days' },
  { name: 'Composite Toe Shoes', moq: '300 pairs', leadTime: '40-50 days' },
  { name: 'Anti-Static Work Shoes', moq: '500 pairs', leadTime: '30-40 days' },
  { name: 'Electrical Hazard Boots', moq: '300 pairs', leadTime: '40-50 days' },
  { name: 'Puncture-Resistant Footwear', moq: '300 pairs', leadTime: '35-45 days' },
  { name: 'Chemical-Resistant Boots', moq: '200 pairs', leadTime: '45-55 days' },
];

const certifications = [
  { name: 'CE EN ISO 20345', description: 'European Safety Footwear Standard' },
  { name: 'ASTM F2413', description: 'US Safety Footwear Standard' },
  { name: 'ISO 9001', description: 'Quality Management System' },
  { name: 'LA', description: 'China Safety Footwear Certification' },
];

const capabilities = [
  { name: 'Direct Injection PU', description: 'Dual-density PU direct injection for lightweight safety boots' },
  { name: 'Goodyear Welt', description: 'Traditional welt construction for heavy-duty durability' },
  { name: 'Steel/Composite Toe Cap', description: '200J impact resistance with integrated toe protection' },
  { name: 'Kevlar Midsole', description: 'Flexible puncture-resistant midsole insertion' },
];
---

<PageLayout
  title="Qingdao Safety First Footwear Co., Ltd. - Safety Shoes Manufacturer"
  description="Verified supplier profile for Qingdao Safety First Footwear, a professional safety and work boot manufacturer in Qingdao, Shandong. CE EN ISO 20345 and ASTM F2413 certified, specializing in steel toe boots, composite toe shoes, and electrical hazard footwear."
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Suppliers', url: '/suppliers/' },
    { name: 'Shandong', url: '/suppliers/' },
    { name: 'Qingdao Safety First', url: '/suppliers/qingdao-safety-first/' },
  ]}
>
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="badge-success">Verified Supplier</span>
      <span class="badge-primary">Safety Footwear</span>
    </div>
    <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
      Qingdao Safety First Footwear Co., Ltd.
    </h1>
    <p class="text-lg text-neutral-600">
      Professional safety footwear manufacturer based in <strong>Qingdao, Shandong Province</strong> — a major industrial manufacturing center in northern China. Fully certified to <strong>CE EN ISO 20345</strong> and <strong>ASTM F2413</strong> standards, specializing in steel toe boots, composite toe shoes, and specialized protective footwear.
    </p>
  </div>

  <div class="rounded-xl overflow-hidden mb-8">
    <img src="/images/suppliers/qingdao-safety.jpg" alt="Qingdao Safety First Safety Footwear" class="w-full h-64 md:h-80 object-cover" />
  </div>

  <div class="grid md:grid-cols-4 gap-6 mb-12">
    <div class="card text-center">
      <div class="text-2xl font-bold text-primary-600 mb-1">Qingdao</div>
      <div class="text-sm text-neutral-500">Location</div>
    </div>
    <div class="card text-center">
      <div class="text-2xl font-bold text-primary-600 mb-1">2006</div>
      <div class="text-sm text-neutral-500">Established</div>
    </div>
    <div class="card text-center">
      <div class="text-2xl font-bold text-primary-600 mb-1">1.5M</div>
      <div class="text-sm text-neutral-500">Annual Capacity</div>
    </div>
    <div class="card text-center">
      <div class="text-2xl font-bold text-primary-600 mb-1">100+</div>
      <div class="text-sm text-neutral-500">Brand Partners</div>
    </div>
  </div>

  <div class="prose prose-lg max-w-none mb-12">
    <h2>Company Overview</h2>
    <p>Qingdao Safety First Footwear Co., Ltd. has been manufacturing <strong>certified safety footwear</strong> for over 18 years. Located in the industrial hub of Qingdao, the factory benefits from direct access to the <strong>Qingdao port</strong> — one of China's busiest export terminals — ensuring efficient global shipping logistics.</p>
    <p>The facility covers <strong>12,000 square meters</strong> with <strong>5 production lines</strong> including two <strong>DESMA direct injection machines</strong> from Germany. Monthly production capacity exceeds <strong>120,000 pairs</strong>, with a workforce of 200+ skilled employees trained in safety footwear manufacturing standards.</p>

    <h2>Product Catalog</h2>
    <div class="overflow-x-auto">
      <table class="min-w-full border border-neutral-200 rounded-lg overflow-hidden">
        <thead class="bg-neutral-50">
          <tr>
            <th class="px-4 py-3 text-left text-sm font-semibold text-neutral-700">Product Category</th>
            <th class="px-4 py-3 text-left text-sm font-semibold text-neutral-700">MOQ</th>
            <th class="px-4 py-3 text-left text-sm font-semibold text-neutral-700">Lead Time</th>
            <th class="px-4 py-3 text-left text-sm font-semibold text-neutral-700">FOB Price Range</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-neutral-100">
          {products.map(p => (
            <tr class="hover:bg-neutral-50">
              <td class="px-4 py-3 text-sm font-medium text-neutral-900">{p.name}</td>
              <td class="px-4 py-3 text-sm text-neutral-600">{p.moq}</td>
              <td class="px-4 py-3 text-sm text-neutral-600">{p.leadTime}</td>
              <td class="px-4 py-3 text-sm text-neutral-600">$10 – $28 / pair</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <h2>Safety Standards Compliance</h2>
    <div class="grid md:grid-cols-2 gap-4 not-prose mb-6">
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-5">
        <h3 class="font-bold text-amber-900 mb-2">CE EN ISO 20345</h3>
        <p class="text-sm text-amber-800 mb-2">European safety footwear standard — all products available in SB, S1, S1P, S2, S3, S4, S5 protection classes</p>
        <ul class="text-sm text-amber-700 space-y-1">
          <li>• Impact resistance: 200J</li>
          <li>• Compression resistance: 15,000N</li>
          <li>• Anti-slip: SRC certified</li>
        </ul>
      </div>
      <div class="bg-blue-50 border border-blue-200 rounded-lg p-5">
        <h3 class="font-bold text-blue-900 mb-2">ASTM F2413</h3>
        <p class="text-sm text-blue-800 mb-2">US safety footwear standard — I/75 and C/75 rated products available</p>
        <ul class="text-sm text-blue-700 space-y-1">
          <li>• Impact: I/75 (75 ft-lb)</li>
          <li>• Compression: C/75 (2,500 lb)</li>
          <li>• EH rated options available</li>
        </ul>
      </div>
    </div>

    <h2>Manufacturing Capabilities</h2>
    <div class="grid md:grid-cols-2 gap-4 not-prose">
      {capabilities.map(c => (
        <div class="bg-white border border-neutral-200 rounded-lg p-4">
          <h3 class="font-semibold text-neutral-900 mb-1">{c.name}</h3>
          <p class="text-sm text-neutral-600">{c.description}</p>
        </div>
      ))}
    </div>

    <h2>Quality Control & Testing</h2>
    <p>Every safety shoe undergoes comprehensive testing in the factory's <strong>in-house SATRA-accredited laboratory</strong>:</p>
    <ul>
      <li><strong>Toe cap impact test</strong>: 200J steel, 100J composite — every batch sampled</li>
      <li><strong>Sole penetration resistance</strong>: ≥ 1,100N (steel), ≥ 1,000N (Kevlar)</li>
      <li><strong>Electrical hazard resistance</strong>: 18kV for 1 minute (EH rated models)</li>
      <li><strong>Anti-static resistance</strong>: 100kΩ – 1,000MΩ (ESD models)</li>
      <li><strong>Sole abrasion</strong>: ≤ 150mm³ volume loss</li>
      <li><strong>Oil resistance</strong>: No degradation after 24h immersion</li>
    </ul>

    <h2>Market & Export</h2>
    <div class="grid md:grid-cols-3 gap-4 not-prose">
      <div class="bg-primary-50 border border-primary-100 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary-600">45%</div>
        <div class="text-sm text-neutral-600">Europe</div>
      </div>
      <div class="bg-primary-50 border border-primary-100 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary-600">35%</div>
        <div class="text-sm text-neutral-600">North America</div>
      </div>
      <div class="bg-primary-50 border border-primary-100 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary-600">20%</div>
        <div class="text-sm text-neutral-600">Middle East & Others</div>
      </div>
    </div>

    <h2>Certifications</h2>
    <div class="flex flex-wrap gap-3 not-prose">
      {certifications.map(c => (
        <div class="bg-green-50 border border-green-200 rounded-lg px-4 py-2">
          <div class="font-semibold text-green-800 text-sm">{c.name}</div>
          <div class="text-xs text-green-600">{c.description}</div>
        </div>
      ))}
    </div>

    <h2>Contact Information</h2>
    <div class="bg-neutral-50 rounded-lg p-6 not-prose">
      <div class="grid md:grid-cols-2 gap-4">
        <div>
          <p class="text-sm text-neutral-500">Address</p>
          <p class="font-medium text-neutral-900">Jimo District, Qingdao, Shandong, China</p>
        </div>
        <div>
          <p class="text-sm text-neutral-500">Business Type</p>
          <p class="font-medium text-neutral-900">Manufacturer (OEM/ODM)</p>
        </div>
        <div>
          <p class="text-sm text-neutral-500">Employees</p>
          <p class="font-medium text-neutral-900">200 – 260</p>
        </div>
        <div>
          <p class="text-sm text-neutral-500">Annual Revenue</p>
          <p class="font-medium text-neutral-900">US$8M – US$15M</p>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-primary-600 text-white rounded-xl p-8 text-center">
    <h3 class="text-2xl font-bold mb-3">Need Certified Safety Footwear?</h3>
    <p class="mb-6 text-primary-100">Get connected with CE and ASTM certified safety shoe manufacturers in Qingdao.</p>
    <a href="/contact/" class="inline-block bg-white text-primary-600 font-semibold px-8 py-3 rounded-lg hover:bg-primary-50 transition-colors">Contact Us for Introduction</a>
  </div>
</PageLayout>
