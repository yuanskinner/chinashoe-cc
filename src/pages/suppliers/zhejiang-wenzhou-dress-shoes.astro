---
import PageLayout from '@layouts/PageLayout.astro';

const products = [
  { name: 'Oxford Shoes', moq: '200 pairs', leadTime: '45-60 days' },
  { name: 'Derby Shoes', moq: '200 pairs', leadTime: '45-60 days' },
  { name: 'Monk Strap Shoes', moq: '150 pairs', leadTime: '45-60 days' },
  { name: 'Brogue Shoes', moq: '200 pairs', leadTime: '50-65 days' },
  { name: 'Whole Cut Shoes', moq: '150 pairs', leadTime: '50-65 days' },
];

const certifications = [
  { name: 'BSCI', description: 'Business Social Compliance Initiative' },
  { name: 'ISO 9001', description: 'Quality Management System' },
  { name: 'WRAP', description: 'Worldwide Responsible Accredited Production' },
  { name: 'CE', description: 'European Conformity' },
];

const capabilities = [
  { name: 'Hand-Welting', description: 'Traditional craftsmanship for luxury segments' },
  { name: 'Blake Construction', description: 'Italian-style flexible dress shoes' },
  { name: 'Goodyear Machine', description: 'Automated welting for consistent quality' },
  { name: 'Hand Finishing', description: 'Burnishing, polishing, and antiquing' },
];
---

<PageLayout
  title="Zhejiang Wenzhou Dress Shoes Factory"
  description="Verified supplier profile for a traditional dress shoe manufacturer in Wenzhou, Zhejiang. Specializing in classic formal footwear including oxfords, derbies, and monk strap shoes."
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Suppliers', url: '/suppliers/' },
    { name: 'Zhejiang', url: '/suppliers/zhejiang/' },
    { name: 'Wenzhou Dress Shoes', url: '/suppliers/zhejiang-wenzhou-dress-shoes/' },
  ]}
>
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="badge-success">Verified Supplier</span>
      <span class="badge-primary">Dress Shoes</span>
    </div>
    <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
      Zhejiang Wenzhou Dress Shoes Factory
    </h1>
    <p class="text-lg text-neutral-600">
      Traditional dress shoe manufacturer with over 25 years of experience in classic formal footwear. Located in Wenzhou, China's historic leather goods capital, producing premium oxfords, derbies, and monk strap shoes.
    </p>
  </div>

  <!-- Featured Image -->
  <div class="rounded-xl overflow-hidden mb-8">
    <img
      src="https://images.unsplash.com/photo-1614252369475-531eba835eb1?w=1200&h=400&fit=crop"
      alt="Classic Dress Shoes"
      class="w-full h-64 md:h-80 object-cover"
    />
  </div>

  <!-- Quick Info -->
  <div class="grid md:grid-cols-4 gap-6 mb-12">
    <div class="card text-center">
      <div class="text-2xl font-bold text-primary-600 mb-1">Wenzhou</div>
      <div class="text-sm text-neutral-500">Location</div>
    </div>
    <div class="card text-center">
      <div class="text-2xl font-bold text-primary-600 mb-1">1998</div>
      <div class="text-sm text-neutral-500">Established</div>
    </div>
    <div class="card text-center">
      <div class="text-2xl font-bold text-primary-600 mb-1">800K</div>
      <div class="text-sm text-neutral-500">Annual Capacity</div>
    </div>
    <div class="card text-center">
      <div class="text-2xl font-bold text-primary-600 mb-1">25+</div>
      <div class="text-sm text-neutral-500">Years Experience</div>
    </div>
  </div>

  <!-- Company Overview -->
  <div class="prose prose-lg max-w-none mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Company Overview</h2>
    
    <p class="text-neutral-600 mb-4">
      Wenzhou has been China's center for leather goods manufacturing for over a century, and our factory carries on this tradition. Founded in 1998, we have grown from a small workshop to a comprehensive dress shoe manufacturer serving clients across Europe, North America, and Asia.
    </p>
    
    <p class="text-neutral-600 mb-4">
      Our 20,000 square meter facility combines traditional craftsmanship with modern quality management. We employ over 400 workers, including a dedicated team of pattern makers and sample technicians who work closely with clients to develop unique products.
    </p>
    
    <p class="text-neutral-600 mb-4">
      We specialize in classic formal footwear construction, including Goodyear welt, Blake stitch, and hand-welting methods. Our craftsmen are trained in traditional European shoemaking techniques passed down through generations, ensuring products meet the expectations of discerning formal footwear consumers.
    </p>
    
    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Market Focus</h3>
    
    <p class="text-neutral-600 mb-4">
      Our primary markets include European private label brands, American department store footwear programs, and Asian premium footwear labels. We understand the different style preferences across markets—European clients typically prefer sleeker, narrower profiles while American markets often favor broader, more substantial constructions.
    </p>
    
    <p class="text-neutral-600 mb-4">
      We offer flexible manufacturing capabilities to serve different market requirements, from entry-level Goodyear welted shoes to premium hand-welted luxury footwear. Our leather sourcing networks span Italy, Spain, India, and domestic Chinese tanneries to meet varied price points.
    </p>
  </div>

  <!-- Product Lines Table -->
  <h2 class="text-2xl font-bold text-neutral-900 mb-6">Product Lines</h2>
  <div class="overflow-x-auto mb-12">
    <table class="w-full">
      <thead>
        <tr class="border-b border-neutral-200">
          <th class="text-left py-3 px-4 font-semibold text-neutral-700">Product Category</th>
          <th class="text-left py-3 px-4 font-semibold text-neutral-700">MOQ</th>
          <th class="text-left py-3 px-4 font-semibold text-neutral-700">Lead Time</th>
        </tr>
      </thead>
      <tbody>
        {products.map(product => (
          <tr class="border-b border-neutral-100">
            <td class="py-3 px-4 text-neutral-700">{product.name}</td>
            <td class="py-3 px-4 text-neutral-600">{product.moq}</td>
            <td class="py-3 px-4 text-neutral-600">{product.leadTime}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Certifications -->
  <h2 class="text-2xl font-bold text-neutral-900 mb-6">Certifications</h2>
  <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4 mb-12">
    {certifications.map(cert => (
      <div class="card">
        <div class="text-lg font-semibold text-neutral-900 mb-1">{cert.name}</div>
        <div class="text-sm text-neutral-600">{cert.description}</div>
      </div>
    ))}
  </div>

  <!-- Capabilities -->
  <h2 class="text-2xl font-bold text-neutral-900 mb-6">Key Capabilities</h2>
  <div class="grid md:grid-cols-2 gap-4 mb-12">
    {capabilities.map(cap => (
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 rounded-full bg-primary-100 flex items-center justify-center flex-shrink-0">
          <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <div>
          <div class="font-semibold text-neutral-900">{cap.name}</div>
          <div class="text-sm text-neutral-600">{cap.description}</div>
        </div>
      </div>
    ))}
  </div>

  <!-- AI Rating Section -->
  <div class="bg-primary-50 rounded-xl p-6 mb-12">
    <h3 class="text-lg font-bold text-neutral-900 mb-4">AI Supplier Rating</h3>
    <div class="grid md:grid-cols-4 gap-4">
      <div class="text-center">
        <div class="text-3xl font-bold text-primary-600">4.6/5</div>
        <div class="text-sm text-neutral-600">Overall Score</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-bold text-primary-600">4.7</div>
        <div class="text-sm text-neutral-600">Quality</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-bold text-primary-600">4.5</div>
        <div class="text-sm text-neutral-600">Communication</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-bold text-primary-600">4.6</div>
        <div class="text-sm text-neutral-600">Delivery</div>
      </div>
    </div>
  </div>

  <!-- Contact CTA -->
  <div class="bg-neutral-50 rounded-xl p-8 text-center">
    <h3 class="text-xl font-bold text-neutral-900 mb-3">Interested in This Supplier?</h3>
    <p class="text-neutral-600 mb-6 max-w-2xl mx-auto">
      Contact us to request a quote, schedule a factory visit, or discuss your specific requirements with this verified supplier.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/contact/" class="btn-primary">Request Quote</a>
      <a href="/sourcing/moq-negotiation-guide/" class="btn-outline">MOQ Negotiation Tips</a>
    </div>
  </div>
</PageLayout>
