---
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import SearchModal from '@components/SearchModal.astro';
import { SEOProps, generateOrganizationSchema, generateWebsiteSchema } from '@utils/seo';

interface Props extends SEOProps {
  class?: string;
}

const {
  title,
  description,
  image,
  type,
  publishedTime,
  modifiedTime,
  authors,
  tags,
  canonicalUrl,
  noindex,
  class: className,
} = Astro.props;

const siteUrl = 'https://chinashoe.cc';
const pageUrl = canonicalUrl ? `${siteUrl}${canonicalUrl}` : Astro.url.href;
const pageImage = image || `${siteUrl}/og-default.jpg`;

const organizationSchema = generateOrganizationSchema();
const websiteSchema = generateWebsiteSchema();
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title.includes('ChinaShoe') ? title : `${title} | ChinaShoe.cc`}</title>
    <meta name="title" content={title.includes('ChinaShoe') ? title : `${title} | ChinaShoe.cc`} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    
    <!-- Canonical URL -->
    <link rel="canonical" href={pageUrl} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type || 'website'} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={pageImage} />
    <meta property="og:site_name" content="ChinaShoe.cc" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {authors && authors.map(author => <meta property="article:author" content={author} />)}
    {tags && tags.map(tag => <meta property="article:tag" content={tag} />)}
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={pageUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={pageImage} />
    <meta name="twitter:site" content="@chinashoecc" />
    <meta name="twitter:creator" content="@chinashoecc" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    
    <!-- Alternate Languages (for future i18n) -->
    <link rel="alternate" hreflang="en" href={pageUrl} />
    <link rel="alternate" hreflang="zh-Hans" href={pageUrl} />
    <link rel="alternate" hreflang="x-default" href={pageUrl} />
    
    <!-- Schema.org Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    
    <!-- Preconnect to external resources -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Mermaid.js for diagram rendering -->
    <script src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        if (typeof mermaid !== 'undefined') {
          mermaid.initialize({
            startOnLoad: true,
            theme: 'default',
            themeVariables: {
              primaryColor: '#B91C1C',
              primaryTextColor: '#fff',
              primaryBorderColor: '#991B1B',
              lineColor: '#525252',
              secondaryColor: '#FEE2E2',
              tertiaryColor: '#FFF7ED',
            },
            flowchart: {
              useMaxWidth: true,
              htmlLabels: true,
              curve: 'basis',
            },
          });
        }
      });
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <Header />
    <SearchModal />
    <main class={`flex-1 ${className || ''}`}>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  @import '@styles/global.css';
</style>
